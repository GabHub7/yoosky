# ══════════════════════════════════════════════════════════
#  VIPRNESTORE — Environment Variables (Production)
#  Copy file ini ke .env dan isi semua nilainya
# ══════════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production
VERCEL=1

# ─── SESSION (WAJIB — generate random string panjang) ────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=GANTI_STRING_RANDOM_64_KARAKTER_DI_SINI

# ─── SUPABASE DATABASE (WAJIB) ───────────────────────────
# Dapat dari: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# PENTING: pakai SERVICE_ROLE key (bukan anon key).
# Server butuh full read/write ke keyvalue_store, dan RLS sekarang
# memblokir akses anon sepenuhnya. Service role key BYPASS RLS —
# JANGAN PERNAH expose key ini ke browser/client-side code.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxx

# Optional — untuk auto-create tabel Supabase jika belum ada
SUPABASE_DB_PASSWORD=password_database_supabase_kamu

# ─── ADMIN AWAL (opsional, hanya dipakai saat pertama kali initDB jalan) ──
# Kalau tidak diisi, password admin akan di-generate random dan
# di-print SEKALI ke log server saat start — cek log lalu ganti
# lewat Admin Panel setelah login pertama.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=

# ─── Hanya untuk menjalankan seed-settings.js secara lokal ───
# JANGAN diisi di env Vercel — ini cuma dipakai sekali dari lokal.
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=

# ─── CLOUDFLARE TURNSTILE (opsional — anti-bot login) ────
# Daftar gratis di: https://dash.cloudflare.com → Turnstile
# Aktif otomatis saat kedua key ini diisi. Kosongkan = Turnstile dimatikan.
# TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxx
# TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PAKASIR QRIS (isi setelah daftar di pakasir.com) ────
# Setting ini JUGA bisa diisi dari Admin Panel → Settings → PakKasir
# Tapi lebih aman disimpan di env var
# PAKASIR_API_KEY=your_api_key_here
# PAKASIR_PROJECT=your_project_name_here

# ──────────────────────────────────────────────────────────
#  CATATAN PENTING:
#  - JANGAN set ADMIN_USERNAME / ADMIN_PASSWORD hardcoded di kode manapun
#  - Setelah set env di Vercel, jalankan seed-settings.js dari lokal
#    (dengan SEED_ADMIN_USERNAME / SEED_ADMIN_PASSWORD di .env lokal)
#    untuk push credentials ke Supabase
# ──────────────────────────────────────────────────────────
