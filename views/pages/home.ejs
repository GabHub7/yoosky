}

/* Scrollbar hidden */
#popular-track::-webkit-scrollbar{display:none;}
</style>

<!-- ══ SCRIPTS ══ -->
<script>
/* Carousel */
(function(){
  let slides=[],cur=0,total=1,timer=null;
  const IV=4500;
  async function init(){
    try{const r=await fetch('/api/banners');slides=await r.json();}catch{slides=[];}
    const track=document.getElementById('carousel-track');
    const dots=document.getElementById('carousel-dots');
    if(!slides.length){total=1;return;}
    document.getElementById('c-slide-default')?.remove();
    track.innerHTML=slides.map((s,i)=>{
      const cl=s.link&&s.link!=='/';
      return`<div style="flex:0 0 100%;position:relative;overflow:hidden;"${cl?` onclick="window.location='${s.link}'" style="flex:0 0 100%;position:relative;overflow:hidden;cursor:pointer;"`:''}>
        <img src="${s.imageUrl}" alt="${s.title||''}" loading="${i===0?'eager':'lazy'}"
             style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
             onerror="this.style.display='none'">
        <div style="position:absolute;inset:0;background:linear-gradient(105deg,rgba(0,0,0,.78) 0%,rgba(0,0,0,.3) 55%,transparent 100%);z-index:1;"></div>
        <div style="position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;justify-content:center;padding:clamp(14px,4vw,30px) clamp(18px,6vw,50px);max-width:65%;">
          ${s.title?`<div style="font-size:clamp(16px,4vw,38px);font-weight:900;color:#fff;line-height:1.1;text-shadow:0 2px 20px rgba(0,0,0,.8);">${s.title}</div>`:''}
          ${s.subtitle?`<div style="font-size:clamp(10px,1.8vw,14px);color:rgba(255,255,255,.7);margin-top:6px;">${s.subtitle}</div>`:''}
          ${cl?`<div style="display:inline-flex;align-items:center;gap:5px;margin-top:12px;padding:8px 18px;border-radius:10px;font-size:11px;font-weight:800;background:linear-gradient(135deg,#fbbf24,#f97316);color:#fff;width:fit-content;"><iconify-icon icon="mdi:arrow-right" style="font-size:12px;"></iconify-icon> Lihat Detail</div>`:''}
        </div>
      </div>`;
    }).join('');
    total=slides.length;
    dots.innerHTML=slides.map((_,i)=>`<div class="c-dot${i===0?' active':''}" onclick="goSlide(${i})"></div>`).join('');
    if(total>1){startAuto();addSwipe();}
    goSlide(0);
  }
  window.goSlide=function(idx){if(total<=1)return;cur=((idx%total)+total)%total;document.getElementById('carousel-track').style.transform=`translateX(-${cur*100}%)`;document.querySelectorAll('.c-dot').forEach((d,i)=>d.classList.toggle('active',i===cur));};
  function startAuto(){clearInterval(timer);timer=setInterval(()=>goSlide(cur+1),IV);}
  function addSwipe(){const w=document.getElementById('carousel-wrap');w.addEventListener('touchstart',e=>{clearInterval(timer);w._tx=e.touches[0].clientX;},{passive:true});w.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-w._tx;if(Math.abs(dx)>38)goSlide(cur+(dx<0?1:-1));startAuto();},{passive:true});}
  document.addEventListener('DOMContentLoaded',init);
})();

/* Filter */
function filterProducts(cat){
  document.querySelectorAll('[data-category]').forEach(c=>{c.style.display=(cat==='all'||c.dataset.category===cat)?'':'none';});
  document.querySelectorAll('.fpill').forEach(b=>{
    const active=b.dataset.pf===cat;
    b.classList.toggle('active',active);
    if(active){b.style.background='#2563eb';b.style.color='#fff';b.style.borderColor='#2563eb';}
    else{b.style.background='rgba(13,26,77,.8)';b.style.color='rgba(148,163,184,.8)';b.style.borderColor='rgba(37,99,235,.3)';}
  });
}

/* Popular products */
async function loadPopular(){
  const track=document.getElementById('popular-track');
  if(!track)return;
  try{
    const data=<%- JSON.stringify(popularProducts) %>;
    if(!data.length){track.innerHTML='<p style="font-size:11px;color:rgba(148,163,184,.3);padding:10px;">Belum ada produk populer</p>';return;}
    const badges=['BEST','HOT','TOP','NEW','SALE'];
    const badgeBgs=['#ef4444','#f59e0b','#3b82f6','#22c55e','#a855f7'];
    track.innerHTML=data.map((p,i)=>{
      const isOut=!(p.stockCount>0);
      const price=p.items&&p.items.length>0?p.items[0].p:null;
      const plat=p.platforms&&p.platforms.length>0?p.platforms[0].toUpperCase():'';
      const badge=p.badge||badges[i%5];
      const bg=badgeBgs[i%5];
      const platClr=plat==='IOS'?'#93c5fd':'#4ade80';
      const platBg=plat==='IOS'?'rgba(59,130,246,.2)':'rgba(34,197,94,.15)';
      return`<div onclick="location.href='/buy/${p.id}'" style="flex-shrink:0;min-width:155px;max-width:155px;scroll-snap-align:start;border-radius:12px;overflow:hidden;background:#0d1a4a;border:1px solid rgba(37,99,235,.22);cursor:pointer;transition:border-color .2s,transform .15s;"
        onmouseover="this.style.borderColor='rgba(37,99,235,.55)';this.style.transform='translateY(-2px)'"
        onmouseout="this.style.borderColor='rgba(37,99,235,.22)';this.style.transform=''">
        <div style="position:relative;height:110px;overflow:hidden;">
          ${badge?`<span style="position:absolute;top:6px;left:6px;z-index:10;font-size:9px;font-weight:900;padding:2px 6px;border-radius:4px;background:${bg};color:#fff;">${badge}</span>`:''}
          ${plat?`<span style="position:absolute;top:6px;right:6px;z-index:10;font-size:8px;font-weight:800;padding:2px 5px;border-radius:3px;background:${platBg};color:${platClr};">${plat}</span>`:''}
          ${p.image?`<img src="${p.image}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">`:`<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(37,99,235,.06);"><iconify-icon icon="solar:gamepad-bold" style="font-size:28px;color:rgba(37,99,235,.35);"></iconify-icon></div>`}
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(13,26,77,.8) 0%,transparent 55%);pointer-events:none;"></div>
        </div>
        <div style="padding:9px;">
          <div style="font-size:11px;font-weight:800;color:#e2e8f0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:5px;">${p.name}</div>
          ${price?`<div style="font-size:11px;font-weight:900;color:#60a5fa;margin-bottom:8px;">Rp ${Number(price).toLocaleString('id-ID')}</div>`:''}
          <button style="width:100%;padding:7px 0;border-radius:7px;font-size:10px;font-weight:900;color:${isOut?'rgba(255,255,255,.25)':'#fff'};background:${isOut?'rgba(255,255,255,.04)':'linear-gradient(135deg,#1d4ed8,#2563eb)'};border:${isOut?'1px solid rgba(255,255,255,.06)':'none'};display:flex;align-items:center;justify-content:center;gap:4px;${isOut?'cursor:not-allowed;':''}" ${isOut?'disabled':''}>
            <iconify-icon icon="${isOut?'mdi:close-circle-outline':'mdi:shopping'}" style="font-size:11px;"></iconify-icon>${isOut?'Habis':'Beli'}
          </button>
        </div>
      </div>`;
    }).join('');
    // drag scroll
    let down=false,sx,sl;
    track.addEventListener('mousedown',e=>{down=true;track.style.cursor='grabbing';sx=e.pageX-track.offsetLeft;sl=track.scrollLeft;e.preventDefault();});
    track.addEventListener('mouseleave',()=>{down=false;track.style.cursor='';});
    track.addEventListener('mouseup',()=>{down=false;track.style.cursor='';});
    track.addEventListener('mousemove',e=>{if(!down)return;track.scrollLeft=sl-(e.pageX-track.offsetLeft-sx)*1.2;});
  }catch(e){track.innerHTML='';}
}

document.addEventListener('DOMContentLoaded',loadPopular);

/* Notifikasi pembelian user lain */
(function(){
  const names=['Rizky','Andi','Dimas','Farhan','Wanda','Putra','Bintang','Kevin','Abil','Hergi','Rehan','Dwi','Yoga','Fajar','Indra','Naufal','Aldi','Salsa','Sinta','Reza'];
  const cities=['Jakarta','Bandung','Surabaya','Medan','Semarang','Makassar','Bekasi','Tangerang','Depok','Bogor','Yogyakarta','Palembang'];
  const toast=document.getElementById('purchase-toast');
  if(!toast)return;
  const textEl=document.getElementById('pt-text');
  const timeEl=toast.querySelector('#pt-time span');
  const avatarEl=document.getElementById('pt-avatar');
  let products=[];
  try{products=<%- JSON.stringify(popularProducts) %>;}catch(e){products=[];}
  let hideTimer=null, cycleTimer=null, dismissed=false;

  function pick(arr){return arr[Math.floor(Math.random()*arr.length)];}

  function showToast(){
    if(dismissed||!products.length)return;
    const p=pick(products);
    const name=pick(names);
    const city=pick(cities);
    const mins=Math.floor(Math.random()*28)+1;
    avatarEl.textContent=name.charAt(0).toUpperCase();
    textEl.innerHTML=`<strong style="color:#fff;">${name}</strong> dari ${city} baru saja membeli <strong style="color:#60a5fa;">${p.name}</strong>`;
    timeEl.textContent=mins<=1?'Baru saja':`${mins} menit yang lalu`;
    toast.style.transform='translateY(0)';
    toast.style.opacity='1';
    clearTimeout(hideTimer);
    hideTimer=setTimeout(hidePurchaseToast,5000);
  }

  window.hidePurchaseToast=function(){
    toast.style.transform='translateY(140%)';
    toast.style.opacity='0';
  };

  function loop(){
    showToast();
    cycleTimer=setTimeout(loop,Math.floor(Math.random()*5000)+8000);
  }
  setTimeout(loop,4000);
})();

</script>
