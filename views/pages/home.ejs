<style>
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
@keyframes marqueeAnim{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
@keyframes pulse{0%,100%{opacity:.6}50%{opacity:1}}

/* Carousel */
#carousel-track>div{flex:0 0 100%;width:100%;height:100%;position:relative;overflow:hidden;}
.c-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.25);cursor:pointer;flex-shrink:0;transition:all .35s cubic-bezier(.4,0,.2,1);}
.c-dot.active{width:26px;border-radius:4px;background:linear-gradient(90deg,#38bdf8,#6366f1,#38bdf8);background-size:200% 100%;animation:dotShimmer 1.6s linear infinite;box-shadow:0 0 10px rgba(99,102,241,.6);}
@keyframes dotShimmer{0%{background-position:0% 50%}100%{background-position:200% 50%}}

/* Product grid: 3 col sm, 4 col lg */
/* nav-btn-desktop: hide on mobile, show on sm+ */
.nav-btn-desktop{display:none;}
@media(min-width:640px){
  #product-grid{grid-template-columns:repeat(3,1fr);}
  .nav-btn-desktop{display:inline-flex!important;}
}
@media(min-width:1024px){
  #product-grid{grid-template-columns:repeat(4,1fr);}
}

/* Card hover */
.pcard:hover{border-color:rgba(37,99,235,.55)!important;transform:translateY(-3px)!important;}
.pcard:active{transform:scale(.97)!important;opacity:.88;}

/* Filter active */
.fpill.active{background:#2563eb!important;color:#fff!important;border-color:#2563eb!important;}

/* Trust badges: 4 col on sm+ */
