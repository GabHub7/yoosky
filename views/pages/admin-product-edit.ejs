<%
const pageTitle = 'Edit Produk';
%>
<style>
.hm-input{width:100%;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);color:#fff;font-size:13px;transition:all .2s;font-family:'Inter',sans-serif;}
.hm-input:focus{outline:none;border-color:rgba(37,99,235,.6);background:rgba(37,99,235,.06);}
.section-card{background:rgba(255,255,255,.02);border:1px solid rgba(37,99,235,.2);border-radius:14px;padding:20px;margin-bottom:16px;}
.key-chip{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:6px;font-size:10px;font-family:monospace;background:rgba(37,99,235,.12);border:1px solid rgba(37,99,235,.25);color:#a5b4fc;margin:2px;}
</style>

<div class="min-h-screen pt-20 pb-24 px-4">
<div class="max-w-2xl mx-auto">

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-black text-white">Edit Produk</h1>
      <p class="text-zinc-500 text-sm mt-0.5" id="productNameLabel">Memuat...</p>
    </div>
    <a href="/admin" class="flex items-center gap-1.5 px-3 py-2 rounded-lg border border-white/10 text-zinc-400 hover:text-white hover:bg-white/5 text-xs font-bold transition-all">
      <iconify-icon icon="mdi:arrow-left"></iconify-icon> Kembali
    </a>
  </div>

  <!-- ── GAMBAR PRODUK ── -->
  <div class="section-card">
    <h2 class="text-sm font-black text-white mb-4 flex items-center gap-2">
      <iconify-icon icon="mdi:image" class="text-blue-400 text-lg"></iconify-icon> Gambar Produk
    </h2>
    <div id="imgPreviewWrap" class="w-full h-44 rounded-xl border-2 border-dashed border-blue-500/30 bg-blue-500/5 flex items-center justify-center overflow-hidden mb-3">
      <img id="imgPreview" src="" alt="" class="w-full h-full object-cover hidden">
      <span id="imgPlaceholder" class="text-zinc-600 text-sm">Belum ada gambar</span>
    </div>
    <input type="file" id="imgFileInput" accept="image/*" class="hidden" onchange="uploadBanner(event)">
    <div class="flex gap-2 mb-2">
      <button onclick="document.getElementById('imgFileInput').click()"
        class="flex-1 py-2 rounded-lg text-xs font-bold text-blue-400 border border-blue-500/30 hover:bg-blue-500/10 transition-all flex items-center justify-center gap-1.5">
        <iconify-icon icon="mdi:upload" class="text-sm"></iconify-icon> Upload File
      </button>
    </div>
    <input type="text" id="imgUrlInput" class="hm-input text-sm" placeholder="Atau paste URL gambar (https://...)" oninput="previewImg(this.value)">
    <p class="text-[10px] text-zinc-600 mt-1.5">Gambar akan tampil di halaman produk pengguna</p>
  </div>

  <!-- ── STATUS ── -->
  <div class="section-card">
    <h2 class="text-sm font-black text-white mb-3 flex items-center gap-2">
      <iconify-icon icon="mdi:shield-check" class="text-blue-400 text-lg"></iconify-icon> Status Produk
    </h2>
    <div class="flex gap-3">
      <button id="btn-active" onclick="setStatus('active')"
        class="flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5">
        <iconify-icon icon="mdi:check-circle"></iconify-icon> Aktif
      </button>
      <button id="btn-inactive" onclick="setStatus('inactive')"
        class="flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5">
        <iconify-icon icon="mdi:close-circle"></iconify-icon> Nonaktif
      </button>
    </div>
  </div>

  <!-- ── PLATFORM ── -->
  <div class="section-card">
    <h2 class="text-sm font-black text-white mb-3 flex items-center gap-2">
      <iconify-icon icon="mdi:cellphone" class="text-blue-400 text-lg"></iconify-icon> Platform
    </h2>
    <div class="flex gap-3">
      <button id="btn-android" onclick="togglePlatform('android')"
        class="flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5">
        <iconify-icon icon="mdi:android" class="text-sm"></iconify-icon> Android
      </button>
      <button id="btn-ios" onclick="togglePlatform('ios')"
        class="flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5">
        <iconify-icon icon="mdi:apple" class="text-sm"></iconify-icon> iOS
      </button>
    </div>
    <p class="text-[10px] text-zinc-600 mt-2">Pilih platform yang didukung produk ini (bisa keduanya)</p>
  </div>

  <!-- ── HARGA PAKET ── -->
  <div class="section-card">
    <h2 class="text-sm font-black text-white mb-1 flex items-center gap-2">
      <iconify-icon icon="mdi:tag-multiple" class="text-blue-400 text-lg"></iconify-icon> Harga Paket
    </h2>
    <p class="text-[11px] text-zinc-500 mb-4">Atur durasi dan harga untuk setiap paket produk</p>
    <div id="pricingRows" class="space-y-2 mb-3"></div>
    <button onclick="addPricingRow()"
      class="w-full py-2.5 rounded-xl text-xs font-bold text-blue-400 border border-dashed border-blue-500/30 hover:bg-blue-500/10 transition-all flex items-center justify-center gap-1.5">
      <iconify-icon icon="mdi:plus-circle" class="text-sm"></iconify-icon> Tambah Paket
    </button>
    <p class="text-[10px] text-zinc-600 mt-2">Contoh: 7 hari → Rp 15.000 | 30 hari → Rp 50.000</p>
  </div>

  <!-- ── KEYS / STOK ── -->
  <div class="section-card">
    <h2 class="text-sm font-black text-white mb-1 flex items-center gap-2">
      <iconify-icon icon="mdi:key-variant" class="text-blue-400 text-lg"></iconify-icon> Keys & Stok
    </h2>
    <p class="text-[11px] text-zinc-500 mb-4">Stok produk ditentukan dari jumlah keys yang tersedia</p>

    <!-- Info stok per paket -->
    <div id="stockInfo" class="space-y-2 mb-4"></div>

    <!-- Tambah keys -->
    <div class="rounded-xl p-4" style="background:rgba(37,99,235,.06);border:1px solid rgba(37,99,235,.2)">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-bold text-blue-300">Tambah / Ganti Keys</span>
        <div class="flex gap-1">
          <button id="modeAppend" onclick="setKeysMode('append')"
            class="px-2 py-1 rounded text-[10px] font-bold transition-all">+ Tambah</button>
          <button id="modeReplace" onclick="setKeysMode('replace')"
            class="px-2 py-1 rounded text-[10px] font-bold transition-all">↺ Ganti Semua</button>
        </div>
      </div>
      <textarea id="keysInput" class="hm-input font-mono text-xs resize-none" rows="6"
        placeholder="Masukkan keys, satu per baris&#10;Contoh:&#10;FF7-001:7&#10;FF30-001:30&#10;ML7-001:7"></textarea>
      <p class="text-[10px] text-zinc-600 mt-1.5">
        Format tag durasi: <code class="text-blue-400">KEY:HARI</code> (misal <code class="text-blue-400">FF7-001:7</code> untuk paket 7 hari)
      </p>
    </div>

    <!-- Preview keys existing -->
    <div id="existingKeys" class="mt-3 hidden">
      <div class="flex items-center justify-between mb-2">
        <span class="text-[11px] text-zinc-500" id="keyCountLabel"></span>
        <button onclick="clearAllKeys()" class="text-[10px] text-red-400 hover:text-red-300 transition-colors">Hapus Semua Keys</button>
      </div>
      <div id="keyChips" class="max-h-32 overflow-y-auto"></div>
    </div>
  </div>

  <!-- ── TOMBOL SIMPAN ── -->
  <div class="flex gap-3 mt-2">
    <button onclick="saveProduct()"
      class="btn-gaming flex-1 py-3.5 text-sm font-black flex items-center justify-center gap-2">
      <iconify-icon icon="mdi:check-circle" class="text-lg"></iconify-icon> Simpan Perubahan
    </button>
    <button onclick="confirmDelete()"
      class="px-5 py-3.5 rounded-xl bg-red-500/15 text-red-400 border border-red-500/35 hover:bg-red-500/25 font-bold text-sm transition-all flex items-center gap-2">
      <iconify-icon icon="mdi:trash"></iconify-icon>
    </button>
  </div>

</div>
</div>

<script>
let currentProduct = null;
let selectedStatus = 'active';
let keysMode = 'append';
let selectedPlatforms = [];
let pricingOptions = [];

// ─── Load produk ───
async function loadProduct() {
  const id = new URLSearchParams(location.search).get('id');
  if (!id) { showToast('ID produk tidak ditemukan', 'error'); return; }

  const res = await fetch('/admin/product/' + id);
  const data = await res.json();
  if (!data.success) { showToast(data.message || 'Gagal memuat', 'error'); return; }

  currentProduct = data.data;
  document.getElementById('productNameLabel').textContent = currentProduct.name;

  // Gambar
  const img = currentProduct.image || currentProduct.bannerUrl || '';
  document.getElementById('imgUrlInput').value = img;
  previewImg(img);

  // Status
  selectedStatus = currentProduct.status || 'active';
  updateStatusBtns();

  // Platforms
  selectedPlatforms = currentProduct.platforms || [];
  updatePlatformBtns();

  // Pricing Options
  if (currentProduct.pricingOptions && currentProduct.pricingOptions.length > 0) {
    pricingOptions = currentProduct.pricingOptions.map(o => ({ days: o.days, price: o.price }));
  } else if (currentProduct.items && currentProduct.items.length > 0) {
    pricingOptions = currentProduct.items.map(item => {
      const m = (item.l || '').match(/(\d+)\s+DAYS/i);
      return { days: m ? parseInt(m[1]) : 0, price: item.p || 0 };
    }).filter(o => o.days > 0);
  } else {
    pricingOptions = [];
  }
  renderPricingRows();

  // Keys
  renderKeyInfo();
  setKeysMode('append');
}

function previewImg(url) {
  const img = document.getElementById('imgPreview');
  const ph  = document.getElementById('imgPlaceholder');
  if (url && url.trim()) {
    img.src = url.trim();
    img.classList.remove('hidden');
    ph.classList.add('hidden');
    img.onerror = () => { img.classList.add('hidden'); ph.classList.remove('hidden'); };
  } else {
    img.classList.add('hidden');
    ph.classList.remove('hidden');
  }
}

async function uploadBanner(e) {
  const file = e.target.files[0];
  if (!file) return;
  const fd = new FormData();
  fd.append('banner', file);
  const res  = await fetch('/admin/upload-banner', { method: 'POST', body: fd });
  const data = await res.json();
  if (data.success) {
    document.getElementById('imgUrlInput').value = data.bannerUrl;
    previewImg(data.bannerUrl);
    showToast('Gambar berhasil diupload', 'success');
  } else {
    showToast(data.message || 'Gagal upload', 'error');
  }
}

// ─── Status ───
function setStatus(s) {
  selectedStatus = s;
  updateStatusBtns();
}
function updateStatusBtns() {
  const a = document.getElementById('btn-active');
  const i = document.getElementById('btn-inactive');
  a.className = selectedStatus === 'active'
    ? 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-emerald-500/50 bg-emerald-500/15 text-emerald-400'
    : 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-white/10 text-zinc-500 hover:text-white';
  i.className = selectedStatus === 'inactive'
    ? 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-red-500/50 bg-red-500/15 text-red-400'
    : 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-white/10 text-zinc-500 hover:text-white';
}

// ─── Platform ───
function togglePlatform(p) {
  const idx = selectedPlatforms.indexOf(p);
  if (idx === -1) selectedPlatforms.push(p); else selectedPlatforms.splice(idx, 1);
  updatePlatformBtns();
}
function updatePlatformBtns() {
  const a = document.getElementById('btn-android');
  const i = document.getElementById('btn-ios');
  a.className = selectedPlatforms.includes('android')
    ? 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-emerald-500/50 bg-emerald-500/15 text-emerald-400'
    : 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-white/10 text-zinc-500 hover:text-white';
  i.className = selectedPlatforms.includes('ios')
    ? 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-sky-400/50 bg-sky-500/15 text-sky-300'
    : 'flex-1 py-2.5 rounded-xl text-xs font-black border transition-all flex items-center justify-center gap-1.5 border-white/10 text-zinc-500 hover:text-white';
}

// ─── Pricing ───
function renderPricingRows() {
  const container = document.getElementById('pricingRows');
  if (pricingOptions.length === 0) {
    container.innerHTML = '<p class="text-center text-zinc-600 text-xs py-3">Belum ada paket harga. Klik "+ Tambah Paket".</p>';
    return;
  }
  container.innerHTML = pricingOptions.map((opt, i) => `
    <div class="flex gap-2 items-center p-3 rounded-xl" style="background:rgba(37,99,235,.06);border:1px solid rgba(37,99,235,.2)">
      <div class="flex-1 flex gap-2 items-center">
        <input type="number" value="${opt.days}" min="1" placeholder="Hari"
          class="hm-input text-sm text-center font-bold" style="width:70px"
          oninput="pricingOptions[${i}].days=parseInt(this.value)||0">
        <span class="text-zinc-500 text-xs shrink-0">hari</span>
        <div class="flex-1 relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-xs font-bold">Rp</span>
          <input type="number" value="${opt.price}" min="0" step="1000" placeholder="Harga"
            class="hm-input text-sm pl-9 font-bold"
            oninput="pricingOptions[${i}].price=parseInt(this.value)||0">
        </div>
      </div>
      <button onclick="removePricingRow(${i})"
        class="shrink-0 w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/25 text-red-400 hover:bg-red-500/20 transition-all flex items-center justify-center text-lg font-black">×</button>
    </div>
  `).join('');
}

function addPricingRow() {
  pricingOptions.push({ days: 7, price: 0 });
  renderPricingRows();
}

function removePricingRow(i) {
  pricingOptions.splice(i, 1);
  renderPricingRows();
}

// ─── Keys Mode ───
function setKeysMode(mode) {
  keysMode = mode;
  const a = document.getElementById('modeAppend');
  const r = document.getElementById('modeReplace');
  a.className = mode === 'append'
    ? 'px-2 py-1 rounded text-[10px] font-bold transition-all bg-indigo-500/20 text-blue-300 border border-blue-500/30'
    : 'px-2 py-1 rounded text-[10px] font-bold transition-all text-zinc-500 hover:text-white border border-transparent';
  r.className = mode === 'replace'
    ? 'px-2 py-1 rounded text-[10px] font-bold transition-all bg-orange-500/20 text-orange-300 border border-orange-500/30'
    : 'px-2 py-1 rounded text-[10px] font-bold transition-all text-zinc-500 hover:text-white border border-transparent';
}

// ─── Render info keys/stok ───
function renderKeyInfo() {
  const p = currentProduct;
  const keys = p.keys || [];
  const totalKeys = keys.length;

  // Stok per item
  const stockHtml = (p.items || []).map(item => {
    const m = (item.l || '').match(/(\d+)\s+DAYS/i);
    const days = m ? parseInt(m[1]) : null;
    let stok;
    if (days) {
      const tagged = keys.filter(k => { const pts = k.split(':'); return pts.length > 1 && parseInt(pts[pts.length-1]) === days; }).length;
      const generic = keys.filter(k => !k.includes(':')).length;
      stok = tagged > 0 ? tagged : generic;
    } else {
      stok = keys.filter(k => !k.includes(':')).length;
    }
    const color = stok === 0 ? 'text-red-400 border-red-500/30 bg-red-500/10' : stok < 5 ? 'text-yellow-400 border-yellow-500/30 bg-yellow-500/10' : 'text-emerald-400 border-emerald-500/30 bg-emerald-500/10';
    return `<div class="flex items-center justify-between p-3 rounded-xl border ${color}">
      <span class="text-xs font-bold text-white">${item.l}</span>
      <span class="text-xs font-black">${stok} stok</span>
    </div>`;
  }).join('');
  document.getElementById('stockInfo').innerHTML = stockHtml;

  // Preview keys existing
  const wrap = document.getElementById('existingKeys');
  if (totalKeys > 0) {
    wrap.classList.remove('hidden');
    document.getElementById('keyCountLabel').textContent = `${totalKeys} key tersimpan`;
    const chips = keys.slice(0, 30).map(k => `<span class="key-chip">${k}</span>`).join('');
    document.getElementById('keyChips').innerHTML = chips + (totalKeys > 30 ? `<span class="key-chip text-zinc-500">+${totalKeys - 30} lainnya</span>` : '');
  } else {
    wrap.classList.add('hidden');
  }
}

async function clearAllKeys() {
  if (!confirm('Hapus semua keys? Stok akan menjadi 0.')) return;
  const res = await fetch(`/admin/product/keys/${currentProduct.id}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ keys: '', mode: 'replace' })
  });
  const data = await res.json();
  if (data.success) {
    currentProduct.keys = [];
    renderKeyInfo();
    showToast('Semua keys dihapus', 'success');
  }
}

// ─── Simpan ───
async function saveProduct() {
  const imgUrl  = document.getElementById('imgUrlInput').value.trim();
  const keysRaw = document.getElementById('keysInput').value.trim();

  // Validasi harga
  const validPricing = pricingOptions.filter(o => o.days > 0);
  if (validPricing.length === 0) {
    showToast('Tambahkan minimal 1 paket harga', 'error');
    return;
  }

  const res = await fetch(`/admin/product/${currentProduct.id}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      bannerUrl: imgUrl,
      status: selectedStatus,
      keys: keysRaw,
      keysMode,
      platforms: selectedPlatforms,
      pricingOptions: validPricing
    })
  });
  const data = await res.json();
  if (data.success) {
    showToast('Produk berhasil disimpan!', 'success');
    currentProduct = data.data;
    document.getElementById('keysInput').value = '';
    renderKeyInfo();
  } else {
    showToast(data.message || 'Gagal menyimpan', 'error');
  }
}

async function confirmDelete() {
  if (!confirm('Hapus produk "' + currentProduct.name + '"? Tidak bisa dikembalikan.')) return;
  const res = await fetch(`/admin/product/delete/${currentProduct.id}`, { method: 'POST' });
  const data = await res.json();
  if (data.success) { showToast('Produk dihapus', 'success'); setTimeout(() => location.href = '/admin', 1000); }
  else showToast(data.message, 'error');
}

function showToast(msg, type='info') {
  let c = document.getElementById('toast-container');
  if (!c) { c = document.createElement('div'); c.id = 'toast-container'; document.body.appendChild(c); }
  const t = document.createElement('div');
  const cls = { success:'bg-emerald-500/20 border-emerald-500/40 text-emerald-300', error:'bg-red-500/20 border-red-500/40 text-red-300', info:'bg-indigo-500/20 border-indigo-500/40 text-blue-300' };
  t.className = `fixed top-4 right-4 z-[99999] px-4 py-3 rounded-xl border backdrop-blur-sm text-sm font-bold ${cls[type]||cls.info} translate-x-0 transition-all`;
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => { t.style.opacity='0'; setTimeout(() => t.remove(), 300); }, 3000);
}

document.addEventListener('DOMContentLoaded', loadProduct);
</script>
