<%
const pageTitle = 'Cek Pesanan';
%>

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-[#0d0d20]/95 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center justify-between h-16">
            <a href="/" class="flex items-center gap-3">
                <% if (settings?.logoUrl) { %>
                <img src="<%= settings.logoUrl %>" alt="Logo" class="h-9 w-auto object-contain" style="max-width:36px;">
                <% } else { %>
                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:#3b82f6;">
                    <iconify-icon icon="mdi:store" style="color:#fff;font-size:18px;"></iconify-icon>
                </div>
                <% } %>
                <span class="font-bold text-xl font-bold" style="background:linear-gradient(135deg,#38bdf8,#93c5fd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;"><%= settings.siteName || 'YOOSKY STORE' %></span>
            </a>
            <a href="/" class="text-xs font-medium text-zinc-400 hover:text-white transition-colors">
                <iconify-icon icon="mdi:arrow-left" class="text-sm"></iconify-icon> Kembali
            </a>
        </div>
    </div>
</nav>

<div class="min-h-screen pt-20 pb-10 px-4">
    <div class="max-w-lg mx-auto">
        <div class="bg-[#0a1435] rounded-xl border border-white/10 shadow-2xl overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
                <h3 class="text-sm font-bold text-white flex items-center gap-2">
                    <iconify-icon icon="mdi:package-variant-closed" class="text-blue-400"></iconify-icon> Cek Pesanan
                </h3>
            </div>

            <div class="p-5 space-y-4">
                <p class="text-xs text-zinc-500 leading-relaxed">
                    Masukkan <strong class="text-blue-400">Kode Pesanan</strong> yang Anda dapatkan saat pembelian.
                </p>

                <form method="POST" action="/invoice" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-zinc-400 mb-2">Kode Pesanan</label>
                        <input type="text" name="code" required class="form-input uppercase font-mono tracking-wider" placeholder="Contoh: VR-A1B2-C3D4" maxlength="14" autofocus>
                    </div>

                    <% if (error) { %>
                        <div class="p-3 rounded-lg bg-red-500/10 border border-red-500/30 flex items-center gap-2">
                            <iconify-icon icon="mdi:alert-circle" class="text-red-400 text-lg"></iconify-icon>
                            <span class="text-xs text-red-400"><%= error %></span>
                        </div>
                    <% } %>

                    <% if (transaction) { %>
                        <div class="p-4 rounded-lg bg-blue-500/10 border border-blue-500/20 space-y-3">
                            <div class="flex items-center justify-between">
                                <span class="text-xs text-zinc-400">Status</span>
                                <% if (transaction.status === 'done') { %>
                                    <span class="status-badge status-done">SELESAI</span>
                                <% } else if (transaction.status === 'pending') { %>
                                    <span class="status-badge status-pending">PENDING</span>
                                <% } else { %>
                                    <span class="status-badge status-cancelled">BATAL</span>
                                <% } %>
                            </div>

                            <div class="flex items-center justify-between">
                                <span class="text-xs text-zinc-400">Produk</span>
                                <span class="text-xs text-white font-medium"><%= transaction.productName %></span>
                            </div>

                            <div class="flex items-center justify-between">
                                <span class="text-xs text-zinc-400">Durasi</span>
                                <span class="text-xs text-white font-medium"><%= transaction.duration %></span>
                            </div>

                            <% if (transaction.originalPrice && transaction.voucherDiscount) { %>
                            <div class="flex items-center justify-between">
                                <span class="text-xs text-zinc-400">Harga Awal</span>
                                <span class="text-xs text-zinc-500 line-through">Rp <%= transaction.originalPrice.toLocaleString('id-ID') %></span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-xs text-zinc-400">Voucher</span>
                                <span class="text-xs font-bold text-emerald-400">-Rp <%= transaction.voucherDiscount.toLocaleString('id-ID') %></span>
                            </div>
                            <% } %>

                            <div class="flex items-center justify-between">
                                <span class="text-xs text-zinc-400">Total</span>
                                <span class="text-xs text-blue-400 font-bold">Rp <%= transaction.price.toLocaleString('id-ID') %></span>
                            </div>

                            <div class="flex items-center justify-between">
                                <span class="text-xs text-zinc-400">Waktu</span>
                                <span class="text-xs text-zinc-300"><%= transaction.time %></span>
                            </div>

                            <% if (transaction.status === 'done' && transaction.key) { %>
                                <div class="pt-3 border-t border-white/10">
                                    <span class="text-xs text-zinc-400 block mb-2">Key/Lisensi:</span>
                                    <div class="p-3 rounded-lg bg-black/30 border border-emerald-500/30">
                                        <code id="keyDisplay" class="text-sm text-emerald-400 font-mono break-all font-black">
                                            <%= transaction.key %><% if (transaction.selectedDays) { %> — <%= transaction.selectedDays %> Hari<% } %>
                                        </code>
                                    </div>
                                    <button onclick="copyKey()" id="copyKeyBtn"
                                        class="mt-2 w-full py-2 rounded-lg flex items-center justify-center gap-2 text-xs font-bold transition-all"
                                        style="background:rgba(52,211,153,.12);border:1px solid rgba(52,211,153,.3);color:#34d399;">
                                        <iconify-icon icon="mdi:content-copy"></iconify-icon>
                                        <span id="copyBtnText">Salin Key</span>
                                    </button>
                                    <script>
                                    function copyKey() {
                                        const raw = `<%= transaction.key %><% if (transaction.selectedDays) { %> — <%= transaction.selectedDays %> Hari<% } %>`;
                                        navigator.clipboard.writeText(raw).then(() => {
                                            const btn = document.getElementById('copyKeyBtn');
                                            const txt = document.getElementById('copyBtnText');
                                            btn.style.background = 'rgba(52,211,153,.25)';
                                            txt.textContent = 'Tersalin!';
                                            setTimeout(() => { btn.style.background = 'rgba(52,211,153,.12)'; txt.textContent = 'Salin Key'; }, 2000);
                                        }).catch(() => {
                                            const r = document.createRange();
                                            r.selectNode(document.getElementById('keyDisplay'));
                                            window.getSelection().removeAllRanges();
                                            window.getSelection().addRange(r);
                                        });
                                    }
                                    </script>
                                </div>
                            <% } else if (transaction.status === 'done' && transaction.outOfStock) { %>
                                <div class="pt-3 border-t border-white/10">
                                    <div class="p-3 rounded-lg bg-amber-500/10 border border-amber-500/30 flex items-start gap-2">
                                        <iconify-icon icon="mdi:clock-alert-outline" class="text-amber-400 text-base mt-0.5"></iconify-icon>
                                        <span class="text-xs text-amber-300">Pembayaran sudah diterima, namun stok produk sedang kosong. Admin akan segera memproses dan mengirimkan key kamu manual via WhatsApp.</span>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    <% } %>

                    <button type="submit" class="btn-primary w-full flex items-center justify-center gap-2">
                        <iconify-icon icon="mdi:magnify" class="text-base"></iconify-icon>
                        <span>Cek Status</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
