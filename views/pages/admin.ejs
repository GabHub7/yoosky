}

// ── SETTINGS ──
document.getElementById('settingsForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const fd = new FormData(this);
    const d = await api('/admin/settings/update', Object.fromEntries(fd));
    if (d.success) toast('Pengaturan disimpan!','success');
    else toast(d.message, 'error');
});

// ── QRIS MODE ──
function setQrisMode(mode) {
    document.getElementById('qrisModeVal').value = mode;
    const isStatic = mode === 'static';
    document.getElementById('sectionStatic').classList.toggle('hidden', !isStatic);
    document.getElementById('sectionApi').classList.toggle('hidden', isStatic);
    document.getElementById('modeStaticBtn').className = `flex-1 py-2.5 rounded-xl text-xs font-bold border transition-all flex items-center justify-center gap-1.5 ${isStatic ? 'bg-blue-500/20 border-indigo-500/50 text-blue-300' : 'bg-white/3 border-white/10 text-zinc-500'}`;
    document.getElementById('modeApiBtn').className = `flex-1 py-2.5 rounded-xl text-xs font-bold border transition-all flex items-center justify-center gap-1.5 ${!isStatic ? 'bg-blue-500/20 border-indigo-500/50 text-blue-300' : 'bg-white/3 border-white/10 text-zinc-500'}`;
    // Auto-save mode
    api('/admin/settings/pakasir', { qrisMode: mode, apiKey: '<%= settings.pakasir?.apiKey||"" %>', project: '<%= settings.pakasir?.project||"" %>', apiBaseUrl: '<%= settings.pakasir?.apiBaseUrl||"api.pakasir.com" %>' })
        .then(d => { if(d.success) toast(`Mode QRIS: ${isStatic ? 'Statis' : 'PakKasir API'}`, 'success'); });
}

document.getElementById('pakasirForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const fd = new FormData(this);
    const data = Object.fromEntries(fd);
    data.qrisMode = 'api';
    const d = await api('/admin/settings/pakasir', data);
    if (d.success) toast('Pengaturan API disimpan!','success');
    else toast(d.message, 'error');
});

document.getElementById('qrisStaticForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const fd = new FormData(this);
    if (!fd.get('qrisImage') || !fd.get('qrisImage').size) {
        toast('Pilih file gambar QRIS terlebih dahulu', 'error'); return;
    }
    const btn = this.querySelector('button[type=submit]');
    btn.disabled = true; btn.innerHTML = '<iconify-icon icon="mdi:loading" class="animate-spin"></iconify-icon> Mengupload...';
