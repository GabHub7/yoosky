// ═══ KEY POOL MANAGEMENT ═══
let _allKeys = [];

async function loadKeys() {
    const r = await fetch('/admin/keyspool');
    const d = await r.json();
    if (!d.success) return;
    _allKeys = d.data || [];
    renderKeys(_allKeys);
}

function renderKeys(keys) {
    const list = document.getElementById('keysList');
    const total = document.getElementById('keyTotal');
    const stats = document.getElementById('keyStatsLabel');
    if (!list) return;
    const used = keys.filter(k => k.used).length;
    const avail = keys.length - used;
    if (total) total.textContent = keys.length;
    if (stats) stats.textContent = `${avail} tersedia · ${used} terpakai`;
    if (!keys.length) {
        list.innerHTML = '<div class="text-center py-8 text-zinc-600 text-xs"><iconify-icon icon="mdi:key-off" class="text-3xl block mx-auto mb-2 text-zinc-700"></iconify-icon>Belum ada key</div>';
        return;
    }
    list.innerHTML = keys.map(k => `
        <div class="neon-card p-3 flex items-center gap-3 ${k.used ? 'opacity-60' : ''}">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 ${k.used ? 'bg-zinc-800' : 'bg-blue-500/15 border border-indigo-500/25'}">
                <iconify-icon icon="${k.used ? 'mdi:key-off' : 'mdi:key'}" class="text-base ${k.used ? 'text-zinc-600' : 'text-blue-400'}"></iconify-icon>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="font-mono text-sm font-black text-white">${k.code}</span>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded ${k.used ? 'bg-zinc-700 text-zinc-500' : 'bg-blue-500/20 text-blue-400 border border-blue-500/30'}">
                        ${k.duration} Hari
                    </span>
                    ${k.used ? `<span class="text-[9px] bg-red-500/15 text-red-400 border border-red-500/25 px-1.5 py-0.5 rounded font-bold">TERPAKAI</span>` : '<span class="text-[9px] bg-emerald-500/15 text-emerald-400 border border-emerald-500/25 px-1.5 py-0.5 rounded font-bold">TERSEDIA</span>'}
                </div>
                <div class="text-[10px] text-zinc-500 mt-0.5">
                    ${k.label !== k.duration + ' Hari' ? k.label + ' · ' : ''}
                    ${k.used ? `Digunakan: <span class="text-zinc-400">${k.usedByUsername || '?'}</span>` : `Dibuat: ${new Date(k.createdAt).toLocaleDateString('id-ID')}`}
                </div>
            </div>
            <button onclick="deleteKey('${k.id}')" class="btn-danger py-1 px-2 text-[10px]" ${k.used ? 'disabled style="opacity:.4"' : ''}>
                <iconify-icon icon="mdi:trash-can"></iconify-icon>
            </button>
        </div>`).join('');
}

async function addKey() {
    const code = document.getElementById('newKeyCode').value.trim();
    const duration = document.getElementById('newKeyDuration').value.trim();
    const label = document.getElementById('newKeyLabel').value.trim();
    const note = document.getElementById('newKeyNote').value.trim();
    if (!code || !duration) { toast('Kode dan durasi wajib diisi', 'error'); return; }
    const d = await api('/admin/keyspool/add', { code, duration, label, note });
    if (d.success) {
        toast('Key berhasil ditambahkan!', 'success');
        document.getElementById('newKeyCode').value = '';
        document.getElementById('newKeyDuration').value = '';
        document.getElementById('newKeyLabel').value = '';
        document.getElementById('newKeyNote').value = '';
        _allKeys = d.data;
        renderKeys(_allKeys);
    } else toast(d.message, 'error');
}

async function generateKeys() {
    const count = document.getElementById('genCount').value;
    const duration = document.getElementById('genDuration').value;
    const prefix = document.getElementById('genPrefix').value;
    if (!duration || parseInt(duration) <= 0) { toast('Durasi tidak valid', 'error'); return; }
    const d = await api('/admin/keyspool/generate', { count, duration, prefix });
    if (d.success) {
        toast(`${d.generated} key berhasil dibuat!`, 'success');
        _allKeys = d.data;
        renderKeys(_allKeys);
        const res = document.getElementById('genResult');
        res.classList.remove('hidden');
        res.innerHTML = `<div class="p-3 rounded-xl text-xs font-mono text-blue-300 break-all" style="background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.2)">${d.codes.join('<br>')}</div>`;
    } else toast(d.message, 'error');
}

async function deleteKey(id) {
    if (!confirm('Hapus key ini?')) return;
    const d = await api('/admin/keyspool/delete/' + id, {});
    if (d.success) {
        toast('Key dihapus', 'success');
        _allKeys = _allKeys.filter(k => k.id !== id);
        renderKeys(_allKeys);
    } else toast(d.message, 'error');
}

