// ── USER SEARCH ──
function filterUsers(q) {
    const term = q.trim().toLowerCase();
    const cards = document.querySelectorAll('.user-card');
    let visible = 0;
    cards.forEach(card => {
        const hay = card.getAttribute('data-search') || '';
        const match = !term || hay.includes(term);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
    });
    const empty = document.getElementById('userSearchEmpty');
    if (empty) empty.classList.toggle('hidden', visible > 0 || !term);
}

async function adjustBalance(id, username) {
    const input = prompt(`Tambah/kurangi saldo "${username}"\nIsi angka positif untuk menambah, negatif untuk mengurangi.\nContoh: 50000 atau -20000`);
    if (input === null || input.trim() === '') return;
    const amount = parseInt(input);
    if (isNaN(amount) || amount === 0) { toast('Nominal tidak valid', 'error'); return; }
    const d = await api(`/admin/user/adjust-balance/${id}`, { amount });
    if (d.success) {
        toast(`Saldo ${username} sekarang Rp ${d.balance.toLocaleString('id-ID')}`, 'success');
        setTimeout(() => location.reload(), 800);
    } else toast(d.message, 'error');
}

