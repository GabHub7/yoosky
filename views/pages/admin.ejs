                <textarea name="about" rows="3" class="hm-input"><%= settings.about %></textarea>
            </div>
            <div>
                <div class="setting-row-label">Marquee Text (teks berjalan)</div>
                <input type="text" name="marqueeText" value="<%= settings.marqueeText %>" class="hm-input">
            </div>
            <div>
                <div class="setting-row-label">URL Logo (gambar navbar)</div>
