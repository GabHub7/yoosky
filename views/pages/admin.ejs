<!-- MODAL: Tambah / Edit Produk -->
<div id="modal-product" class="modal-wrap">
    <div class="modal-bg" onclick="closeModal('modal-product')"></div>
    <div class="modal-box">
        <div class="modal-handle"></div>
        <div class="p-5">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-bold text-white flex items-center gap-2" id="modalProductTitle">
                    <iconify-icon icon="mdi:package-variant-plus" class="text-blue-400"></iconify-icon> Tambah Produk
                </h3>
                <button onclick="closeModal('modal-product')" class="w-7 h-7 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-zinc-400">
                    <iconify-icon icon="mdi:close"></iconify-icon>
                </button>
            </div>
            <form id="addProductForm" class="space-y-3" enctype="multipart/form-data">
                <input type="hidden" name="_productId" id="editProductId">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <div class="setting-row-label">Nama Produk *</div>
                        <input type="text" name="name" id="prodName" required class="hm-input" placeholder="Drip Client">
                    </div>
                    <div>
                        <div class="setting-row-label">Kategori</div>
                        <select name="category" id="prodCategory" class="hm-input">
                            <% (settings.categories||[]).forEach(cat => { %>
                            <option value="<%= cat %>"><%= (settings.categoryLabels||{})[cat]||cat %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div>
                    <div class="setting-row-label">Deskripsi</div>
                    <textarea name="description" id="prodDesc" rows="2" class="hm-input" placeholder="Fitur lengkap..."></textarea>
                </div>
                <div>
                    <div class="setting-row-label">Gambar (URL atau upload)</div>
                    <input type="text" name="imageUrl" id="prodImageUrl" class="hm-input mb-2" placeholder="https://cdn.../gambar.png">
                    <input type="file" name="image" accept="image/*" class="hm-input text-xs py-2">
                </div>

                <!-- PRICING TABLE (like deem) -->
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <div class="setting-row-label mb-0">Opsi Harga *</div>
                        <button type="button" onclick="addPricingRow()" class="flex items-center gap-1 text-[11px] text-blue-400 hover:text-blue-300 transition-colors">
                            <iconify-icon icon="mdi:plus-circle"></iconify-icon> Tambah Durasi
                        </button>
                    </div>
                    <div id="pricingRows" class="space-y-2">
                        <div class="flex items-center gap-2 text-[9px] font-bold uppercase tracking-wider text-zinc-600 px-0.5">
                            <div style="flex:0 0 72px">Hari</div>
                            <div class="flex-1">Harga Normal</div>
                            <div class="flex-1">Harga Reseller <span class="normal-case font-normal text-zinc-700">(kosong = pakai %)</span></div>
                            <div style="width:32px"></div>
                        </div>
                        <!-- rows injected by JS -->
                    </div>
                    <p class="text-[10px] text-zinc-600 mt-1">Key format: <code class="text-blue-400">KEY123</code> (generic) atau <code class="text-blue-400">KEY123:7</code> (khusus 7 hari)</p>
                </div>

                <!-- STATUS -->
                <div>
                    <div class="setting-row-label">Status</div>
                    <select name="status" id="prodStatus" class="hm-input">
                        <option value="active">Aktif</option>
                        <option value="inactive">Nonaktif</option>
                    </select>
                </div>

                <!-- KEYS TEXTAREA -->
                <div>
                    <div class="flex items-center justify-between mb-1">
                        <div class="setting-row-label mb-0">Keys / Lisensi</div>
                        <span id="prodKeyCount" class="text-[10px] text-zinc-500"></span>
                    </div>
                    <textarea name="keys" id="prodKeys" rows="5" class="hm-input font-mono text-xs"
                        placeholder="KEY-FF-001&#10;KEY-FF-002:7&#10;KEY-FF-003:30&#10;&#10;Kosongkan = tidak ubah keys (mode edit)"></textarea>
                    <div class="flex gap-2 mt-1" id="keysModeRow">
                        <label class="flex items-center gap-1 text-[11px] text-zinc-400 cursor-pointer">
                            <input type="radio" name="keysMode" value="append" checked class="accent-indigo-500"> Tambah ke stok existing
                        </label>
                        <label class="flex items-center gap-1 text-[11px] text-zinc-400 cursor-pointer">
                            <input type="radio" name="keysMode" value="replace" class="accent-red-500"> Ganti semua keys
                        </label>
                    </div>
                </div>

                <div class="flex gap-2 pt-1">
                    <button type="submit" id="prodSubmitBtn" class="btn-primary flex-1 justify-center py-2.5 text-xs">
                        <iconify-icon icon="mdi:plus"></iconify-icon> <span id="prodSubmitLabel">Tambah Produk</span>
                    </button>
                    <button type="button" onclick="closeModal('modal-product')" class="btn-danger justify-center py-2.5 px-4 text-xs">Batal</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL: Kelola Keys Cepat -->
<div id="modal-keys" class="modal-wrap">
    <div class="modal-bg" onclick="closeModal('modal-keys')"></div>
    <div class="modal-box">
        <div class="modal-handle"></div>
        <div class="p-5">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-sm font-bold text-white flex items-center gap-2">
                    <iconify-icon icon="mdi:key-plus" class="text-emerald-400"></iconify-icon>
                    Keys: <span id="keysModalProductName" class="text-blue-300"></span>
                </h3>
                <button onclick="closeModal('modal-keys')" class="w-7 h-7 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-zinc-400">
                    <iconify-icon icon="mdi:close"></iconify-icon>
                </button>
            </div>
            <div class="mb-3 flex items-center gap-2 p-2.5 rounded-lg bg-indigo-500/8 border border-indigo-500/15">
                <iconify-icon icon="mdi:database" class="text-blue-400 text-sm"></iconify-icon>
                <span class="text-xs text-zinc-400">Stok saat ini: <strong class="text-white" id="keysCurrentCount">—</strong> keys</span>
            </div>
            <form id="addKeysForm" class="space-y-3">
                <input type="hidden" id="keysProductId">
                <div>
                    <div class="setting-row-label">Keys Baru (satu baris = satu key)</div>
                    <textarea id="keysTextarea" rows="8" class="hm-input font-mono text-xs"
                        placeholder="KEY-FF-001&#10;KEY-FF-002:7&#10;KEY-FF-003:30&#10;&#10;Format KEY:HARI untuk duration-specific"></textarea>
                </div>
                <div class="flex gap-3">
                    <label class="flex items-center gap-1.5 text-[11px] text-zinc-400 cursor-pointer">
                        <input type="radio" name="keysAddMode" value="append" checked class="accent-indigo-500"> Tambahkan
                    </label>
                    <label class="flex items-center gap-1.5 text-[11px] text-zinc-400 cursor-pointer">
                        <input type="radio" name="keysAddMode" value="replace" class="accent-red-500"> Ganti semua
                    </label>
                </div>
                <div class="flex gap-2">
                    <button type="submit" class="btn-success flex-1 justify-center py-2.5 text-xs">
                        <iconify-icon icon="mdi:content-save"></iconify-icon> Simpan Keys
                    </button>
                    <button type="button" onclick="closeModal('modal-keys')" class="btn-danger py-2.5 px-4 text-xs">Batal</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL: Tambah Testimoni -->
<div id="modal-testi" class="modal-wrap">
    <div class="modal-bg" onclick="closeModal('modal-testi')"></div>
    <div class="modal-box">
        <div class="modal-handle"></div>
        <div class="p-5">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-bold text-white flex items-center gap-2">
                    <iconify-icon icon="mdi:comment-plus" class="text-blue-400"></iconify-icon> Tambah Testimoni
                </h3>
                <button onclick="closeModal('modal-testi')" class="w-7 h-7 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-zinc-400">
                    <iconify-icon icon="mdi:close"></iconify-icon>
                </button>
            </div>
            <form id="addTestimonialForm" class="space-y-3">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <div class="setting-row-label">Nama *</div>
                        <input type="text" name="name" required class="hm-input" placeholder="Nama pembeli">
                    </div>
                    <div>
                        <div class="setting-row-label">Rating *</div>
                        <select name="rating" required class="hm-input">
                            <option value="5">★★★★★ (5)</option>
                            <option value="4">★★★★☆ (4)</option>
                            <option value="3">★★★☆☆ (3)</option>
                            <option value="2">★★☆☆☆ (2)</option>
                            <option value="1">★☆☆☆☆ (1)</option>
                        </select>
                    </div>
                </div>
                <div>
                    <div class="setting-row-label">Produk (opsional)</div>
                    <input type="text" name="product" class="hm-input" placeholder="Nama produk">
                </div>
                <div>
                    <div class="setting-row-label">Isi Testimoni *</div>
                    <textarea name="text" rows="3" required class="hm-input" placeholder="Tulis testimoni..."></textarea>
                </div>
                <div class="flex gap-4">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="verified" checked class="w-3.5 h-3.5 accent-indigo-500">
                        <span class="text-xs text-zinc-400">Verified</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="featured" checked class="w-3.5 h-3.5 accent-blue-500">
                        <span class="text-xs text-zinc-400">Featured (tampil di home)</span>
                    </label>
                </div>
                <div class="flex gap-2 pt-1">
                    <button type="submit" class="btn-primary flex-1 justify-center py-2.5 text-xs">
                        <iconify-icon icon="mdi:plus"></iconify-icon> Tambah
                    </button>
                    <button type="button" onclick="closeModal('modal-testi')" class="btn-danger py-2.5 px-4 text-xs">Batal</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// ── TOAST ──
function toast(msg, type='info') {
    const styles = {
        success: 'border-green-500/40 text-green-300',
        error:   'border-red-500/40 text-red-300',
        info:    'border-indigo-500/40 text-blue-300',
        warn:    'border-yellow-500/40 text-yellow-300'
    };
    const icons = { success:'mdi:check-circle', error:'mdi:alert-circle', info:'mdi:information', warn:'mdi:alert' };
    const el = document.createElement('div');
    el.className = `toast ${styles[type]||styles.info}`;
    el.innerHTML = `<iconify-icon icon="${icons[type]||icons.info}" class="text-base flex-shrink-0"></iconify-icon><span>${msg}</span>`;
    document.getElementById('toast-container').appendChild(el);
    setTimeout(() => { el.style.opacity='0'; el.style.transition='opacity .3s'; setTimeout(()=>el.remove(),300); }, 3000);
}

// ── LOGOUT ──
function clearAndLogout(e) {
    e.preventDefault();
    localStorage.removeItem('hm_cart');
    localStorage.removeItem('shownNotifs');
    window.location.href = '/logout';
}

// ── SINGLE-DEVICE ADMIN LOCK ──
// Server membalas { sessionRevoked: true } kalau sesi admin ini sudah
// digantikan login dari perangkat lain. Kita pasang sekali di window.fetch
// supaya SEMUA pemanggilan fetch() di halaman ini otomatis kebagian deteksi,
// tanpa perlu ubah satu-satu di tiap tombol/aksi.
let _sessionKicked = false;
const _origFetch = window.fetch.bind(window);
window.fetch = async function(...args) {
    const res = await _origFetch(...args);
    if (!_sessionKicked && res.status === 401) {
        try {
            const clone = res.clone();
            const ct = clone.headers.get('content-type') || '';
            if (ct.includes('application/json')) {
                const data = await clone.json();
                if (data && data.sessionRevoked) {
                    _sessionKicked = true;
                    toast(data.message || 'Sesi admin diakhiri karena login dari perangkat lain', 'error');
                    setTimeout(() => { window.location.href = '/vpr-secure-panel-8x?kicked=1'; }, 1800);
                }
            }
        } catch {}
    }
    return res;
};

// Heartbeat: kabari server tab ini masih aktif, supaya lock tidak expired
// selama admin masih membuka panel (tapi tetap auto-expired kalau tab
// ditutup/koneksi putus, lihat ADMIN_LOCK_TIMEOUT_MS di server).
setInterval(() => {
    if (_sessionKicked || document.hidden) return;
    fetch('/admin/session/heartbeat', { method: 'POST' }).catch(() => {});
}, 90000);


// ── CEK STATUS DATABASE (SUPABASE) ──
(async function checkDbStatus() {
    try {
        const r = await fetch('/admin/db-status');
        const d = await r.json();
        const alertEl = document.getElementById('binid-alert');
        const msgEl   = document.getElementById('binid-msg');
        const content = document.getElementById('dbStatusContent');

        if (!d.hasUrl || !d.hasKey) {
            if (d.hasAnonKeyOnly) {
                if (alertEl) { alertEl.classList.remove('hidden'); msgEl.innerHTML = `⚠️ Yang ke-set itu SUPABASE_ANON_KEY — tapi app ini butuh SUPABASE_SERVICE_ROLE_KEY (beda key!). Lihat Settings → API di dashboard Supabase, copy yang "service_role" (secret), bukan "anon" (public).`; }
                if (content) content.innerHTML = `<div class="flex items-start gap-2 text-red-400"><iconify-icon icon="mdi:alert-circle" class="text-base flex-shrink-0 mt-0.5"></iconify-icon><div><strong>Salah key: app butuh service_role, bukan anon.</strong><br>Env var <code class="bg-black/30 px-1 rounded">SUPABASE_ANON_KEY</code> tidak dibaca sama sekali oleh server ini. Buat env var baru bernama persis <code class="bg-black/30 px-1 rounded">SUPABASE_SERVICE_ROLE_KEY</code> isi dengan secret "service_role" dari Supabase (Project Settings → API), lalu Redeploy.</div></div>`;
            } else {
                const missing = [!d.hasUrl && 'SUPABASE_URL', !d.hasKey && 'SUPABASE_SERVICE_ROLE_KEY'].filter(Boolean).join(' & ');
                if (alertEl) { alertEl.classList.remove('hidden'); msgEl.innerHTML = `⚠️ Env var ${missing} tidak terbaca server ini. Set lalu Redeploy di Vercel (perubahan env var TIDAK otomatis kepakai tanpa redeploy).`; }
                if (content) content.innerHTML = `<div class="flex items-start gap-2 text-red-400"><iconify-icon icon="mdi:alert-circle" class="text-base flex-shrink-0 mt-0.5"></iconify-icon><div><strong>${missing} tidak terbaca di server ini.</strong><br>Env var sudah benar di dashboard Vercel? Coba <b>Redeploy</b> — Vercel tidak otomatis menerapkan env var baru/yang diubah ke deployment yang sudah berjalan.</div></div>`;
            }
        } else if (!d.connected && d.projectPaused) {
            const restoreLink = d.restoreUrl ? `<a href="${d.restoreUrl}" target="_blank" class="underline font-bold">Restore Project di Supabase</a>` : 'dashboard Supabase';
            if (alertEl) { alertEl.classList.remove('hidden'); msgEl.innerHTML = `⚠️ Project Supabase kemungkinan PAUSED atau tabel belum dibuat. Buka dashboard Supabase → restore project → lalu jalankan supabase-schema.sql.`; }
            if (content) content.innerHTML = `<div class="flex items-start gap-2 text-amber-400"><iconify-icon icon="mdi:pause-circle" class="text-base flex-shrink-0 mt-0.5"></iconify-icon><div><strong>Project Supabase kemungkinan besar sedang PAUSED.</strong><br><span class="text-zinc-400 text-[11px]">Supabase free tier auto-pause project setelah 7 hari tidak ada aktivitas. Error kosong <code class="bg-black/30 px-1 rounded">{"message":""}</code> adalah tanda khasnya.</span><br>→ ${restoreLink} dulu, tunggu sampai statusnya "Active", baru coba reload halaman ini.<br><span class="text-zinc-500 text-[11px]">Kalau project sudah Active tapi masih error, berarti tabel belum dibuat — jalankan <code class="bg-black/30 px-1 rounded">supabase-schema.sql</code> di ${d.sqlEditorUrl ? `<a href="${d.sqlEditorUrl}" target="_blank" class="underline">SQL Editor</a>` : 'SQL Editor'}.</span></div></div>`;
        } else if (d.connected && !d.tableExists) {
            if (alertEl) { alertEl.classList.remove('hidden'); msgEl.innerHTML = `⚠️ Gagal konek ke Supabase: ${d.errorMsg || 'unknown error'}`; }
            if (content) content.innerHTML = `<div class="text-red-400">Gagal terkoneksi ke Supabase.<br><span class="text-zinc-500 text-[11px]">${d.errorMsg || 'Tidak ada detail error dari server.'}</span></div>`;
        } else if (!d.tableExists) {
            if (alertEl) { alertEl.classList.remove('hidden'); msgEl.innerHTML = `⚠️ Tabel keyvalue_store belum ada di Supabase. Jalankan supabase-schema.sql di SQL Editor.`; }
            if (content) content.innerHTML = `<div class="flex items-start gap-2 text-red-400"><iconify-icon icon="mdi:alert-circle" class="text-base flex-shrink-0 mt-0.5"></iconify-icon><div><strong>Terkoneksi, tapi tabel keyvalue_store belum ada.</strong><br>Jalankan isi file <code class="bg-black/30 px-1 rounded">supabase-schema.sql</code> di ${d.sqlEditorUrl ? `<a href="${d.sqlEditorUrl}" target="_blank" class="underline">SQL Editor Supabase</a>` : 'SQL Editor Supabase'}.</div></div>`;
        } else {
            if (content) content.innerHTML = `<div class="flex items-center gap-2 text-emerald-400"><iconify-icon icon="mdi:check-circle" class="text-base"></iconify-icon><div>Database terhubung ke Supabase PostgreSQL.<br><span class="text-zinc-500">Project: <code class="text-zinc-400">${d.projectUrl || '—'}</code></span></div></div>`;
        }
    } catch(e) {
        const content = document.getElementById('dbStatusContent');
        if (content) content.innerHTML = `<div class="text-red-400">Gagal cek status database: ${e.message}</div>`;
    }
})();


// ── TAB SWITCH ──
function switchTab(name) {
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('pane-'+name).classList.add('active');
    const nb = document.getElementById('nav-'+name);
    if (nb) nb.classList.add('active');
    window.scrollTo({top:0,behavior:'smooth'});
    if (name === 'testimonials') loadTestimonials();
    if (name === 'keys') loadKeys();
    if (name === 'vouchers') loadVouchers();
    history.replaceState(null, '', '/admin#' + name);
}

// ── HASH ROUTING: auto switch tab dari URL hash ──
document.addEventListener('DOMContentLoaded', () => {
    const validTabs = ['dashboard','products','transactions','users','testimonials','settings','keys','vouchers'];
    const hash = window.location.hash.replace('#', '');
    if (validTabs.includes(hash)) switchTab(hash);
});

// ── MODAL ──
function openModal(id) { document.getElementById(id).classList.add('open'); document.body.style.overflow='hidden'; }
function closeModal(id) { document.getElementById(id).classList.remove('open'); document.body.style.overflow=''; }
// (openAddProductModal, openEditProductModal, openAddKeysModal defined above)
document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.querySelectorAll('.modal-wrap.open').forEach(m => m.classList.remove('open'));
});

// ── API helper ──
async function api(url, data) {
    const r = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
    return r.json();
}

// ── PRODUK: Pricing rows ──
let pricingRowCount = 0;
function addPricingRow(days='', price='', resellerPrice='') {
    const i = pricingRowCount++;
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2';
    row.innerHTML = `
        <div class="flex-1 flex gap-2">
            <div style="flex:0 0 72px">
                <input type="number" name="pricingDays" value="${days}" min="1" required
                    class="hm-input text-xs" placeholder="Hari">
            </div>
            <div class="flex-1">
                <input type="number" name="pricingPrices" value="${price}" min="0" required
                    class="hm-input text-xs" placeholder="Harga Normal (Rp)">
            </div>
            <div class="flex-1">
                <input type="number" name="pricingResellerPrices" value="${resellerPrice}" min="0"
                    class="hm-input text-xs" placeholder="Harga Reseller (Rp)" title="Kosongkan = ikut diskon % global">
            </div>
        </div>
        <button type="button" onclick="this.closest('.flex').remove()" class="w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400 flex-shrink-0">
            <iconify-icon icon="mdi:minus" class="text-sm"></iconify-icon>
        </button>`;
    document.getElementById('pricingRows').appendChild(row);
}

function openAddProductModal() {
    document.getElementById('editProductId').value = '';
    document.getElementById('modalProductTitle').innerHTML = '<iconify-icon icon="mdi:package-variant-plus" class="text-blue-400"></iconify-icon> Tambah Produk';
    document.getElementById('prodSubmitLabel').textContent = 'Tambah Produk';
    document.getElementById('addProductForm').reset();
    document.getElementById('pricingRows').innerHTML = '';
    document.getElementById('prodKeyCount').textContent = '';
    document.getElementById('keysModeRow').style.display = 'none';
    pricingRowCount = 0;
    addPricingRow('7','60000'); addPricingRow('30','150000');
    openModal('modal-product');
}

function openEditProductModal(id, name, category, description, imageUrl, pricing, keyCount, status) {
    document.getElementById('editProductId').value = id;
    document.getElementById('modalProductTitle').innerHTML = '<iconify-icon icon="mdi:pencil" class="text-yellow-400"></iconify-icon> Edit Produk';
    document.getElementById('prodSubmitLabel').textContent = 'Simpan Perubahan';
    document.getElementById('prodName').value = name||'';
    document.getElementById('prodDesc').value = description||'';
    document.getElementById('prodImageUrl').value = imageUrl||'';
    document.getElementById('prodKeys').value = '';
    document.getElementById('prodKeyCount').textContent = `${keyCount} key aktif`;
    document.getElementById('keysModeRow').style.display = 'flex';
    // Set category
    const catSel = document.getElementById('prodCategory');
    if (catSel) { for(let o of catSel.options) { o.selected = (o.value===category); } }
    // Set status
    const stSel = document.getElementById('prodStatus');
    if (stSel) { for(let o of stSel.options) { o.selected = (o.value===status); } }
    // Pricing
    document.getElementById('pricingRows').innerHTML = '';
    pricingRowCount = 0;
    if (pricing && pricing.length) { pricing.forEach(o => addPricingRow(o.days, o.price, o.reseller_price || '')); }
    else addPricingRow('7','60000');
    openModal('modal-product');
}

document.getElementById('addProductForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('prodSubmitBtn');
    const editId = document.getElementById('editProductId').value;
    btn.disabled = true;
    btn.innerHTML = '<iconify-icon icon="mdi:loading" class="animate-spin"></iconify-icon> Menyimpan...';
    const fd = new FormData(this);
    const url = editId ? `/admin/product/edit/${editId}` : '/admin/product/add';
    try {
        const r = await fetch(url, { method:'POST', body:fd });
        const d = await r.json();
        if (d.success) {
            toast(editId ? 'Produk diupdate!' : 'Produk ditambahkan!', 'success');
            closeModal('modal-product');
            setTimeout(()=>{ window.location.href = '/admin#products'; },500);
        } else {
            toast(d.message||'Gagal menyimpan produk','error');
            console.error('[add/edit product] server error:', d);
        }
    } catch(err) {
        toast('Error koneksi: '+err.message,'error');
        console.error('[add/edit product] fetch error:', err);
    }
    btn.disabled = false;
    btn.innerHTML = editId ? '<iconify-icon icon="mdi:pencil"></iconify-icon> Simpan Perubahan' : '<iconify-icon icon="mdi:plus"></iconify-icon> Tambah Produk';
});

// ── KEYS MODAL ──
function openAddKeysModal(pid, productName, currentCount) {
    document.getElementById('keysProductId').value = pid;
    document.getElementById('keysModalProductName').textContent = productName||pid;
    document.getElementById('keysCurrentCount').textContent = currentCount||'?';
    document.getElementById('keysTextarea').value = '';
    openModal('modal-keys');
}

document.getElementById('addKeysForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const pid   = document.getElementById('keysProductId').value;
    const keys  = document.getElementById('keysTextarea').value.trim();
    const mode  = document.querySelector('input[name=keysAddMode]:checked')?.value || 'append';
    if (!keys) { toast('Masukkan minimal 1 key','error'); return; }
    const d = await api(`/admin/product/keys/${pid}`, { keys, mode });
    if (d.success) {
        toast(`Keys disimpan! Total: ${d.keyCount} key`, 'success');
        closeModal('modal-keys');
        const card = document.querySelector(`[data-product-id="${pid}"]`);
        if (card) { const span = card.querySelector('.prod-key-count'); if(span) span.textContent = `${d.keyCount} key`; }
    } else toast(d.message, 'error');
});

async function toggleProduct(id) {
    const d = await api(`/admin/product/toggle/${id}`, {});
    if (d.success) {
        toast('Status diubah', 'success');
        const card = document.querySelector(`[data-product-id="${id}"]`);
        if (card) {
            const badge = card.querySelector('.badge');
            if (badge) {
                badge.className = d.status === 'active' ? 'badge badge-done' : 'badge badge-inactive';
                badge.textContent = d.status === 'active' ? 'Aktif' : 'Off';
            }
        }
    } else toast(d.message, 'error');
}

async function deleteProduct(id) {
    if (!confirm('Hapus produk ini?')) return;
    const d = await api(`/admin/product/delete/${id}`, {});
    if (d.success) {
        toast('Produk dihapus', 'warn');
        const card = document.querySelector(`[data-product-id="${id}"]`);
        if (card) { card.style.transition='opacity .3s,transform .3s'; card.style.opacity='0'; card.style.transform='translateX(20px)'; setTimeout(()=>card.remove(),300); }
    } else toast(d.message, 'error');
}

// ── TRANSAKSI ──
async function deleteTransaction(id) {
    if (!confirm('Hapus transaksi ini?')) return;
    const d = await api(`/admin/transaction/delete/${id}`, {});
    if (d.success) {
        toast('Transaksi dihapus', 'warn');
        const card = document.querySelector(`[data-trx-id="${id}"]`);
        if (card) { card.style.transition='opacity .3s'; card.style.opacity='0'; setTimeout(()=>card.remove(),300); }
    } else toast(d.message, 'error');
}

// ── USERS ──
async function deleteUser(id, name) {
    if (!confirm(`Hapus user "${name}"?`)) return;
    const d = await api(`/admin/user/delete/${id}`, {});
    if (d.success) {
        toast('User dihapus', 'warn');
        const card = document.querySelector(`[data-user-id="${id}"]`);
        if (card) { card.style.transition='opacity .3s'; card.style.opacity='0'; setTimeout(()=>card.remove(),300); }
    } else toast(d.message, 'error');
}

// ── TESTIMONI ──
async function loadTestimonials() {
    const el = document.getElementById('testi-list');
    el.innerHTML = '<div class="text-center py-8 text-zinc-600"><iconify-icon icon="mdi:loading" class="text-2xl animate-spin block mx-auto mb-2 text-blue-400"></iconify-icon><p class="text-xs">Memuat...</p></div>';
    try {
        const list = await (await fetch('/api/testimonials')).json();
        if (!list.length) { el.innerHTML = '<div class="text-center py-10 text-zinc-600 text-xs">Belum ada testimoni</div>'; return; }
        el.innerHTML = list.map(t => {
            const stars = '★'.repeat(t.rating) + '☆'.repeat(5-t.rating);
            const date  = new Date(t.date).toLocaleDateString('id-ID');
            const short = t.text.length > 80 ? t.text.slice(0,80)+'...' : t.text;
            return `
            <div class="neon-card p-3.5 fade-in">
                <div class="flex items-start justify-between gap-2 mb-2">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-600 to-indigo-700 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                            ${t.name.charAt(0).toUpperCase()}
                        </div>
                        <div>
                            <div class="text-xs font-semibold text-white">${t.name}</div>
                            <div class="text-yellow-400 text-xs">${stars}</div>
                        </div>
                    </div>
                    <div class="flex items-center gap-1.5 flex-shrink-0">
                        ${t.verified ? '<span class="badge badge-done">✓ Verified</span>' : '<span class="text-[9px] font-black px-1.5 py-0.5 rounded" style="background:rgba(234,179,8,.15);color:#fbbf24;border:1px solid rgba(234,179,8,.3)">PENDING</span>'}
                        ${t.featured ? '<span class="badge badge-featured">★ Home</span>' : ''}
                    </div>
                </div>
                <p class="text-[11px] text-zinc-400 leading-relaxed mb-2">"${short}"</p>
                <div class="flex items-center justify-between gap-2 flex-wrap">
                    <div class="text-[10px] text-zinc-600">${t.product||'Umum'} · ${date}</div>
                    <div class="flex gap-1.5 flex-wrap">
                        <button onclick="toggleVerified('${t.id}')" class="py-1 px-2 text-[10px] rounded-lg font-bold transition-all" style="${t.verified ? 'background:rgba(16,185,129,.15);color:#34d399;border:1px solid rgba(16,185,129,.3);' : 'background:rgba(234,179,8,.1);color:#fbbf24;border:1px solid rgba(234,179,8,.25);'}">${t.verified ? '✓ Verified' : '○ Verifikasi'}</button>
                        <button onclick="toggleFeatured('${t.id}')" class="btn-warning py-1 px-2 text-[10px]">${t.featured ? 'Unfeature' : '★ Feature'}</button>
                        <button onclick="deleteTestimonial('${t.id}')" class="btn-danger py-1 px-2 text-[10px]"><iconify-icon icon="mdi:trash-can"></iconify-icon></button>
                    </div>
                </div>
            </div>`;
        }).join('');
    } catch(err) {
        el.innerHTML = '<div class="text-center py-6 text-xs text-red-400">Gagal memuat testimoni</div>';
    }
}

document.getElementById('addTestimonialForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const fd = new FormData(this);
    const data = {
        name: fd.get('name'), rating: fd.get('rating'), text: fd.get('text'),
        product: fd.get('product'), verified: fd.get('verified')==='on', featured: fd.get('featured')==='on'
    };
    const d = await api('/admin/testimonial/add', data);
    if (d.success) { toast('Testimoni ditambahkan!','success'); closeModal('modal-testi'); this.reset(); loadTestimonials(); }
    else toast(d.message, 'error');
});

async function deleteTestimonial(id) {
    if (!confirm('Hapus testimoni ini?')) return;
    const d = await api(`/admin/testimonial/delete/${id}`, {});
    if (d.success) { toast('Testimoni dihapus','warn'); loadTestimonials(); }
    else toast(d.message, 'error');
}

async function toggleFeatured(id) {
    const d = await api(`/admin/testimonial/toggle-featured/${id}`, {});
