    </div>
</div>

<!-- ── KEY POOL ── -->
<div id="pane-keys" class="tab-pane">
    <div class="flex items-center justify-between mb-4">
        <div class="section-label mb-0">Manajemen Key Lisensi</div>
        <span class="text-[10px] text-zinc-600" id="keyStatsLabel">—</span>
    </div>

    <!-- Form tambah / generate key -->
    <div class="neon-card p-4 mb-4">
        <div class="text-xs font-bold text-blue-400 mb-3 flex items-center gap-2">
            <iconify-icon icon="mdi:key-plus" class="text-base"></iconify-icon> Tambah Key Manual
        </div>
        <div class="grid grid-cols-2 gap-2 mb-2">
            <div>
                <div class="setting-row-label">Kode Key</div>
                <input type="text" id="newKeyCode" class="hm-input font-mono uppercase" placeholder="HERO-001" maxlength="20" oninput="this.value=this.value.toUpperCase()">
            </div>
            <div>
                <div class="setting-row-label">Durasi (Hari)</div>
                <input type="number" id="newKeyDuration" class="hm-input" placeholder="30" min="1" max="9999">
            </div>
        </div>
        <div class="mb-2">
            <div class="setting-row-label">Label (opsional)</div>
            <input type="text" id="newKeyLabel" class="hm-input" placeholder="30 Hari Akses Premium">
        </div>
        <div class="mb-3">
            <div class="setting-row-label">Catatan (opsional)</div>
            <input type="text" id="newKeyNote" class="hm-input" placeholder="Untuk pelanggan paket...">
        </div>
        <button onclick="addKey()" class="btn-primary w-full">
            <iconify-icon icon="mdi:plus-circle"></iconify-icon> Tambah Key
        </button>
    </div>

    <!-- Generate otomatis -->
    <div class="neon-card p-4 mb-4">
        <div class="text-xs font-bold text-blue-400 mb-3 flex items-center gap-2">
            <iconify-icon icon="mdi:auto-fix" class="text-base"></iconify-icon> Generate Key Otomatis
        </div>
        <div class="grid grid-cols-3 gap-2 mb-2">
            <div>
                <div class="setting-row-label">Jumlah</div>
                <input type="number" id="genCount" class="hm-input" placeholder="5" min="1" max="100" value="5">
            </div>
            <div>
                <div class="setting-row-label">Durasi (Hari)</div>
                <input type="number" id="genDuration" class="hm-input" placeholder="30" min="1" value="30">
            </div>
            <div>
                <div class="setting-row-label">Prefix</div>
                <input type="text" id="genPrefix" class="hm-input uppercase" placeholder="KEY" maxlength="8" value="KEY" oninput="this.value=this.value.toUpperCase()">
            </div>
        </div>
        <button onclick="generateKeys()" class="btn-primary w-full" style="background:linear-gradient(135deg,#2563eb,#3b82f6)">
            <iconify-icon icon="mdi:lightning-bolt"></iconify-icon> Generate Keys
        </button>
        <div id="genResult" class="mt-2 hidden"></div>
    </div>

    <!-- Daftar key -->
    <div class="section-label">Daftar Key (<span id="keyTotal">0</span>)</div>
    <div class="space-y-2" id="keysList">
        <div class="text-center py-6 text-zinc-600 text-xs">
            <iconify-icon icon="mdi:loading" class="text-xl text-blue-400 animate-spin block mx-auto mb-2"></iconify-icon>
            Memuat...
        </div>
    </div>
</div>

<!-- ── VOUCHERS ── -->
<div id="pane-vouchers" class="tab-pane">
    <div class="flex items-center justify-between mb-4">
        <div class="section-label mb-0">Manajemen Voucher Diskon</div>
        <span class="text-[10px] text-zinc-600" id="voucherStatsLabel">—</span>
    </div>

    <!-- Form tambah voucher -->
    <div class="neon-card p-4 mb-4">
        <div class="text-xs font-bold text-green-400 mb-3 flex items-center gap-2">
            <iconify-icon icon="mdi:ticket-percent" class="text-base"></iconify-icon> Tambah Voucher
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-2">
            <div>
                <div class="setting-row-label">Kode Voucher</div>
                <input type="text" id="newVoucherCode" class="hm-input font-mono uppercase" placeholder="DISC30" maxlength="20" oninput="this.value=this.value.toUpperCase()">
            </div>
            <div>
                <div class="setting-row-label">Tipe</div>
                <select id="newVoucherType" class="hm-input">
                    <option value="percent">Persen (%)</option>
                    <option value="nominal">Nominal (Rp)</option>
                </select>
            </div>
            <div>
                <div class="setting-row-label">Nilai</div>
                <input type="number" id="newVoucherValue" class="hm-input" placeholder="10 / 5000" min="1">
            </div>
            <div>
                <div class="setting-row-label">Min. Belanja</div>
                <input type="number" id="newVoucherMin" class="hm-input" placeholder="0 (tanpa min)" min="0" value="0">
            </div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mb-2">
            <div>
                <div class="setting-row-label">Maks. Pemakaian</div>
                <input type="number" id="newVoucherMax" class="hm-input" placeholder="0 = tak terbatas" min="0" value="0">
            </div>
            <div>
                <div class="setting-row-label">Per User</div>
                <input type="number" id="newVoucherPerUser" class="hm-input" placeholder="1" min="1" value="1">
            </div>
            <div>
                <div class="setting-row-label">Kadaluarsa</div>
                <input type="date" id="newVoucherExpiry" class="hm-input">
            </div>
        </div>
        <div class="mb-3">
            <div class="setting-row-label">Deskripsi (opsional)</div>
            <input type="text" id="newVoucherDesc" class="hm-input" placeholder="Diskon 30% untuk semua produk">
        </div>
        <div class="mb-3 flex items-center gap-3 p-3 rounded-xl" style="background:rgba(234,179,8,.06);border:1px solid rgba(234,179,8,.18);">
            <input type="checkbox" id="newVoucherExcludeReseller" class="w-4 h-4 rounded accent-yellow-400">
            <div>
                <div class="text-[11px] font-semibold text-yellow-300">Tidak berlaku untuk Reseller</div>
                <div class="text-[10px] text-zinc-500">Cegah double-discount: reseller tidak bisa pakai voucher ini karena sudah dapat harga reseller</div>
            </div>
        </div>
        <button onclick="addVoucher()" class="btn-primary w-full" style="background:linear-gradient(135deg,#059669,#10b981)">
            <iconify-icon icon="mdi:plus-circle"></iconify-icon> Buat Voucher
        </button>
    </div>

    <!-- Daftar voucher -->
    <div class="space-y-2" id="vouchersList">
        <div class="text-center py-6 text-zinc-600 text-xs">
            <iconify-icon icon="mdi:loading" class="text-xl text-blue-400 animate-spin block mx-auto mb-2"></iconify-icon>
            Memuat...
        </div>
    </div>
</div>

<!-- ── SETTINGS ── -->
<div id="pane-settings" class="tab-pane">
    <div class="section-label mb-3">Pengaturan Situs</div>

    <!-- Status Database Supabase -->
    <div id="dbStatusCard" class="neon-card p-4 mb-3">
        <div class="text-xs font-bold text-emerald-400 mb-3 flex items-center gap-2">
            <iconify-icon icon="mdi:database"></iconify-icon> Status Database (Supabase)
        </div>
        <div id="dbStatusContent" class="text-xs text-zinc-400">Memeriksa koneksi...</div>
    </div>

    <!-- Info Situs -->
    <div class="neon-card p-5 mb-3">
        <div class="text-xs font-bold text-blue-400 mb-4 flex items-center gap-2">
            <iconify-icon icon="mdi:information-outline"></iconify-icon> Informasi Situs
        </div>
        <form id="settingsForm" class="space-y-3">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div>
                    <div class="setting-row-label">Nama Situs</div>
