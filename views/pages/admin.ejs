            </div>
            <div class="pt-2 border-t border-white/5">
                <div class="text-xs font-bold text-blue-400 mb-3 flex items-center gap-2">
                    <iconify-icon icon="mdi:phone"></iconify-icon> Kontak
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div>
                        <div class="setting-row-label">WhatsApp</div>
                        <input type="text" name="whatsapp" value="<%= settings.contact?.whatsapp||'' %>" class="hm-input" placeholder="628xxxxxxxxx">
                    </div>
                    <div>
                        <div class="setting-row-label">Telegram</div>
                        <input type="text" name="telegram" value="<%= settings.contact?.telegram||'' %>" class="hm-input" placeholder="username">
                    </div>
                    <div>
                        <div class="setting-row-label">Email</div>
                        <input type="email" name="email" value="<%= settings.contact?.email||'' %>" class="hm-input">
                    </div>
                </div>
                <div class="mt-3">
                    <div class="setting-row-label">Link Download APK / Channel</div>
                    <input type="url" name="downloadUrl" value="<%= settings.contact?.downloadUrl||'' %>" class="hm-input" placeholder="https://whatsapp.com/channel/... atau link Google Drive APK">
                    <div class="text-[10px] mt-1" style="color:var(--text-3);">Ditampilkan sebagai tombol "Download APK" di halaman produk. Kosongkan untuk menyembunyikan tombol.</div>
                </div>
                <div class="mt-3">
