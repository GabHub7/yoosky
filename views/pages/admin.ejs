        </div>
        <form id="categoryForm" class="space-y-3">
            <div>
                <div class="setting-row-label">Daftar kategori (satu per baris, format: id:Label)</div>
                <textarea name="categories" rows="6" class="hm-input font-mono text-xs"><% (settings.categories||[]).forEach(cat => { %><%= cat %>:<%= (settings.categoryLabels||{})[cat]||cat %>
<% }) %></textarea>
