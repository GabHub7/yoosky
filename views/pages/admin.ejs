// ── KONFIRMASI TRANSAKSI ──
async function confirmTransaction(id) {
    if (!confirm('Konfirmasi pembayaran transaksi ini?')) return;
    const btn = document.getElementById(`trx-confirm-${id}`);
    if (btn) { btn.disabled = true; btn.innerHTML = '<iconify-icon icon="mdi:loading" class="animate-spin"></iconify-icon> Proses...'; }
    const d = await api(`/admin/transaction/confirm/${id}`, {});
    if (d.success) {
        toast(d.type === 'reseller' ? 'User berhasil diupgrade jadi Reseller VIP!' : d.type === 'deposit' ? `Top up saldo dikonfirmasi! Saldo user: Rp ${(d.balance||0).toLocaleString('id-ID')}` : `Konfirmasi berhasil! Key: ${d.key||'-'}`, 'success');
        const badge = document.getElementById(`trx-status-badge-${id}`);
        if (badge) { badge.className = 'badge badge-done'; badge.textContent = 'Done'; }
        if (btn) btn.remove();
        const card = document.querySelector(`[data-trx-id="${id}"]`);
        if (card) card.setAttribute('data-status','done');
    } else {
        toast(d.message || 'Gagal konfirmasi', 'error');
        if (btn) { btn.disabled = false; btn.innerHTML = '<iconify-icon icon="mdi:check-circle"></iconify-icon> Konfirmasi Bayar'; }
    }
}

