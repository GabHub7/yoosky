<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Admin — <%= settings.siteName %></title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">
<script>tailwind.config={theme:{extend:{fontFamily:{inter:['Inter','sans-serif'],orbitron:['Orbitron','sans-serif']}}}}</script>
<style>
:root{--bg:#0b0b1a;--card:#0f0f25;--card2:#12122a;--border:rgba(255,255,255,.07);--accent:#6366f1;}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{font-family:'Inter',sans-serif;background:var(--bg);color:#e0e0e0;overflow-x:hidden;}
body{padding-bottom:80px;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:#2a2a4a;border-radius:3px;}

body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(37,99,235,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(37,99,235,.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}
body>*{position:relative;z-index:1;}

@keyframes fadeInUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
@keyframes slideUp{from{transform:translateY(100%);opacity:0;}to{transform:translateY(0);opacity:1;}}
@keyframes spin{to{transform:rotate(360deg);}}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.4;}}

.fade-in{animation:fadeInUp .3s ease-out both;}
.animate-spin{animation:spin 1s linear infinite;}
.shimmer-text{background:linear-gradient(135deg,#38bdf8,#93c5fd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}

.neon-card{background:var(--card);border:1px solid var(--border);border-radius:14px;transition:border-color .2s;}
.neon-card:hover{border-color:rgba(37,99,235,.25);}

.stat-card{background:linear-gradient(135deg,rgba(37,99,235,.1),rgba(37,99,235,.05));border:1px solid rgba(37,99,235,.2);border-radius:14px;padding:16px;transition:all .2s;}
.stat-card:hover{border-color:rgba(37,99,235,.4);transform:translateY(-2px);}

.hm-input,.form-input{width:100%;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);color:#fff;font-size:13px;transition:all .2s;font-family:'Inter',sans-serif;}
.hm-input:focus,.form-input:focus{outline:none;border-color:rgba(37,99,235,.6);background:rgba(37,99,235,.06);box-shadow:0 0 0 3px rgba(37,99,235,.1);}
.hm-input::placeholder,.form-input::placeholder{color:#52525b;}
select.hm-input{appearance:none;cursor:pointer;}
textarea.hm-input{resize:vertical;min-height:80px;}

.btn-primary{background:linear-gradient(135deg,#6366f1,#6366f1);color:#fff;padding:10px 18px;border-radius:10px;font-weight:700;font-size:12px;border:none;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary:hover{filter:brightness(1.15);transform:translateY(-1px);}
.btn-danger{background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;padding:7px 14px;border-radius:8px;font-weight:600;font-size:11px;border:none;cursor:pointer;transition:filter .2s;display:inline-flex;align-items:center;gap:4px;}
.btn-danger:hover{filter:brightness(1.15);}
.btn-success{background:linear-gradient(135deg,#10b981,#059669);color:#fff;padding:7px 14px;border-radius:8px;font-weight:600;font-size:11px;border:none;cursor:pointer;transition:filter .2s;display:inline-flex;align-items:center;gap:4px;}
.btn-success:hover{filter:brightness(1.15);}
.btn-warning{background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;padding:7px 14px;border-radius:8px;font-weight:600;font-size:11px;border:none;cursor:pointer;transition:filter .2s;display:inline-flex;align-items:center;gap:4px;}

.data-table{width:100%;border-collapse:collapse;}
.data-table th{background:rgba(37,99,235,.1);padding:10px 12px;text-align:left;font-size:10px;font-weight:800;color:#38bdf8;text-transform:uppercase;letter-spacing:.6px;white-space:nowrap;}
.data-table td{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.05);font-size:12px;vertical-align:middle;}
.data-table tr:hover td{background:rgba(37,99,235,.04);}

.badge{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:6px;font-size:10px;font-weight:700;text-transform:uppercase;white-space:nowrap;}
.badge-done{background:rgba(16,185,129,.15);color:#34d399;border:1px solid rgba(16,185,129,.25);}
.badge-pending{background:rgba(234,179,8,.15);color:#facc15;border:1px solid rgba(234,179,8,.25);}
.badge-inactive{background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25);}
.badge-featured{background:rgba(37,99,235,.15);color:#93c5fd;border:1px solid rgba(37,99,235,.25);}

.tab-pane{display:none;}
.tab-pane.active{display:block;animation:fadeInUp .3s ease-out both;}

.modal-wrap{display:none;position:fixed;inset:0;z-index:80;}
.modal-wrap.open{display:flex;align-items:flex-end;justify-content:center;}
@media(min-width:640px){.modal-wrap.open{align-items:center;}}
.modal-bg{position:absolute;inset:0;background:rgba(0,0,0,.75);}
.modal-box{position:relative;background:var(--card);border:1px solid rgba(37,99,235,.2);width:100%;max-height:90vh;overflow-y:auto;border-radius:20px 20px 0 0;animation:slideUp .25s ease-out both;}
@media(min-width:640px){.modal-box{border-radius:16px;max-width:580px;}}
.modal-box::-webkit-scrollbar{width:3px;}
.modal-box::-webkit-scrollbar-thumb{background:#2a2a4a;border-radius:2px;}
.modal-handle{width:40px;height:4px;background:rgba(255,255,255,.12);border-radius:2px;margin:12px auto 0;}

#toast-container{position:fixed;top:12px;right:12px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:12px;background:var(--card);box-shadow:0 8px 32px rgba(0,0,0,.5);font-size:12px;max-width:280px;border:1px solid;animation:fadeInUp .3s ease-out both;}

#admin-nav{position:fixed;bottom:0;left:0;right:0;z-index:70;background:rgba(8,8,22,.98);border-top:1px solid rgba(37,99,235,.15);height:68px;display:flex;align-items:center;justify-content:space-around;padding:0 4px 6px;box-shadow:0 -4px 20px rgba(0,0,0,.5);}
.nav-btn{display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 8px;border-radius:12px;cursor:pointer;transition:all .2s;flex:1;max-width:64px;border:1.5px solid transparent;-webkit-tap-highlight-color:transparent;position:relative;}
.nav-btn .n-icon{font-size:20px;color:#52525b;transition:color .2s;line-height:1;}
.nav-btn .n-label{font-size:9px;font-weight:700;color:#52525b;transition:color .2s;white-space:nowrap;}
.nav-btn.active .n-icon{color:#38bdf8;}
.nav-btn.active .n-label{color:#38bdf8;}
.nav-btn.active{background:rgba(37,99,235,.12);border-color:rgba(37,99,235,.25);}
.nav-btn:active{transform:scale(.88);}
.nav-dot{position:absolute;top:4px;right:6px;width:7px;height:7px;background:#ef4444;border-radius:50%;border:1.5px solid var(--bg);animation:blink 2s infinite;}

.page-top{padding:12px 16px;background:rgba(8,8,22,.95);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:30;}
.prod-card{background:var(--card2);border:1px solid var(--border);border-radius:12px;padding:14px;transition:border-color .2s;display:flex;align-items:center;gap:12px;}
.prod-card:hover{border-color:rgba(37,99,235,.3);}
.section-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#52525b;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.section-label::before{content:'';width:16px;height:2px;background:var(--accent);border-radius:2px;display:block;}
.setting-row-label{font-size:11px;font-weight:700;color:#a1a1aa;margin-bottom:8px;}
</style>
</head>
<body class="font-inter">

<div id="toast-container"></div>

<!-- HEADER -->
<div id="binid-alert" class="hidden px-4 py-2 text-[11px] font-bold text-center" style="background:rgba(234,179,8,.15);border-bottom:1px solid rgba(234,179,8,.3);color:#fbbf24;">
    <iconify-icon icon="mdi:alert" class="align-middle mr-1"></iconify-icon>
    <span id="binid-msg"></span>
</div>

<div class="page-top flex items-center justify-between">
    <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-700 flex items-center justify-center flex-shrink-0">
            <iconify-icon icon="mdi:shield-crown" class="text-white text-base"></iconify-icon>
        </div>
        <div>
            <div class="font-bold text-sm font-black shimmer-text">ADMIN PANEL</div>
            <div class="text-[9px] text-zinc-600"><%= settings.siteName %></div>
        </div>
    </div>
    <div class="flex items-center gap-2">
        <span class="text-[10px] text-zinc-500 hidden sm:block">
            <span class="text-emerald-400 font-bold"><%= stats.doneTransactions %></span> done ·
            <span class="text-yellow-400 font-bold"><%= stats.pendingTransactions %></span> pending
        </span>
        <a href="/" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-white/10 text-zinc-400 hover:text-white hover:bg-white/5 transition-all text-xs">
            <iconify-icon icon="mdi:home" class="text-sm"></iconify-icon>
            <span class="hidden sm:inline">Beranda</span>
        </a>
        <a href="/logout" onclick="clearAndLogout(event)" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-red-500/20 text-red-400 hover:bg-red-500/10 transition-all text-xs">
            <iconify-icon icon="mdi:logout" class="text-sm"></iconify-icon>
        </a>
    </div>
</div>

<!-- MAIN -->
<div class="max-w-4xl mx-auto px-4 py-5">

<!-- ── DASHBOARD ── -->
<div id="pane-dashboard" class="tab-pane active">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-3">
        <div class="stat-card fade-in" style="background:linear-gradient(135deg,rgba(37,99,235,.12),rgba(37,99,235,.06));border-color:rgba(37,99,235,.25);">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] text-zinc-500 font-semibold uppercase tracking-wide">Produk</span>
                <iconify-icon icon="mdi:package-variant" class="text-blue-400 text-lg"></iconify-icon>
            </div>
            <div class="text-2xl font-black text-white font-bold"><%= stats.totalProducts %></div>
            <div class="text-[10px] text-zinc-600 mt-1"><%= stats.activeProducts %> aktif</div>
        </div>
        <div class="stat-card fade-in" style="background:linear-gradient(135deg,rgba(16,185,129,.1),rgba(5,150,105,.05));border-color:rgba(16,185,129,.25);">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] text-zinc-500 font-semibold uppercase tracking-wide">Selesai</span>
                <iconify-icon icon="mdi:check-circle" class="text-emerald-400 text-lg"></iconify-icon>
            </div>
            <div class="text-2xl font-black text-white font-bold"><%= stats.doneTransactions %></div>
            <div class="text-[10px] text-emerald-600 mt-1">transaksi done</div>
        </div>
        <div class="stat-card fade-in" style="background:linear-gradient(135deg,rgba(234,179,8,.1),rgba(245,158,11,.05));border-color:rgba(234,179,8,.25);">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] text-zinc-500 font-semibold uppercase tracking-wide">Pending</span>
                <iconify-icon icon="mdi:clock-outline" class="text-yellow-400 text-lg"></iconify-icon>
            </div>
            <div class="text-2xl font-black text-white font-bold"><%= stats.pendingTransactions %></div>
            <div class="text-[10px] text-yellow-600 mt-1">menunggu</div>
        </div>
        <div class="stat-card fade-in" style="background:linear-gradient(135deg,rgba(22,163,74,.1),rgba(21,128,61,.05));border-color:rgba(22,163,74,.25);">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] text-zinc-500 font-semibold uppercase tracking-wide">Revenue</span>
                <iconify-icon icon="mdi:cash-multiple" class="text-green-400 text-lg"></iconify-icon>
            </div>
            <div class="text-lg font-black text-white font-bold">Rp <%= (stats.totalRevenue/1000).toFixed(0) %>K</div>
            <div class="text-[10px] text-green-600 mt-1">total pendapatan</div>
        </div>
        <div class="stat-card fade-in" style="background:linear-gradient(135deg,rgba(59,130,246,.1),rgba(37,99,235,.05));border-color:rgba(59,130,246,.25);">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] text-zinc-500 font-semibold uppercase tracking-wide">Users</span>
                <iconify-icon icon="mdi:account-group" class="text-blue-400 text-lg"></iconify-icon>
            </div>
            <div class="text-2xl font-black text-white font-bold"><%= stats.totalUsers %></div>
            <div class="text-[10px] text-blue-600 mt-1">member terdaftar</div>
        </div>
        <div class="stat-card fade-in" style="background:linear-gradient(135deg,rgba(234,88,12,.1),rgba(194,65,12,.05));border-color:rgba(234,88,12,.25);">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] text-zinc-500 font-semibold uppercase tracking-wide">Reseller</span>
                <iconify-icon icon="mdi:crown" class="text-orange-400 text-lg"></iconify-icon>
            </div>
            <div class="text-2xl font-black text-white font-bold"><%= stats.totalResellers || 0 %></div>
            <div class="text-[10px] text-orange-600 mt-1">reseller VIP aktif</div>
        </div>
    </div>

    <!-- GRAFIK PENJUALAN 7 HARI -->
    <div class="neon-card p-4 mb-5">
        <div class="section-label mb-3">Grafik Penjualan 7 Hari Terakhir</div>
        <div style="position:relative;height:180px;">
            <canvas id="salesChart"></canvas>
        </div>
    </div>

    <div class="section-label">Quick Actions</div>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 mb-5">
        <button onclick="switchTab('products')" class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-blue-500/10 border border-blue-500/20 hover:bg-blue-500/20 transition-all">
            <iconify-icon icon="mdi:package-variant" class="text-xl text-blue-400"></iconify-icon>
            <span class="text-[10px] font-semibold text-blue-300">Produk</span>
        </button>
        <button onclick="switchTab('transactions')" class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-emerald-500/10 border border-emerald-500/20 hover:bg-emerald-500/20 transition-all">
            <iconify-icon icon="mdi:receipt-text" class="text-xl text-emerald-400"></iconify-icon>
            <span class="text-[10px] font-semibold text-emerald-300">Transaksi</span>
        </button>
        <button onclick="switchTab('users')" class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-blue-500/10 border border-blue-500/20 hover:bg-blue-500/20 transition-all">
            <iconify-icon icon="mdi:account-group" class="text-xl text-blue-400"></iconify-icon>
            <span class="text-[10px] font-semibold text-blue-300">Users</span>
        </button>
        <button onclick="switchTab('testimonials')" class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-blue-500/10 border border-blue-500/20 hover:bg-blue-500/20 transition-all">
            <iconify-icon icon="mdi:comment-quote" class="text-xl text-blue-400"></iconify-icon>
            <span class="text-[10px] font-semibold text-blue-300">Testimoni</span>
        </button>
        <button onclick="switchTab('settings')" class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-amber-500/10 border border-amber-500/20 hover:bg-amber-500/20 transition-all">
            <iconify-icon icon="mdi:cog" class="text-xl text-amber-400"></iconify-icon>
            <span class="text-[10px] font-semibold text-amber-300">Setting</span>
        </button>
        <button onclick="openAddProductModal()" class="flex flex-col items-center gap-1.5 p-3 rounded-xl bg-pink-500/10 border border-pink-500/20 hover:bg-pink-500/20 transition-all">
            <iconify-icon icon="mdi:plus-circle" class="text-xl text-pink-400"></iconify-icon>
            <span class="text-[10px] font-semibold text-pink-300">+Produk</span>
        </button>
    </div>

    <div class="section-label">Transaksi Terbaru</div>
    <div class="neon-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Kode</th>
                        <th>Produk</th>
                        <th>Harga</th>
                        <th>Status</th>
                        <th>Waktu</th>
                    </tr>
                </thead>
                <tbody>
                    <% transactions.slice(0,8).forEach(t => { %>
                    <tr>
                        <td class="font-mono text-blue-400 text-[11px]"><%= t.code %></td>
                        <td class="text-white max-w-[120px] truncate text-xs"><%= t.productName %></td>
                        <td class="text-emerald-400 font-bold whitespace-nowrap text-xs">Rp <%= (t.price/1000).toFixed(0) %>K</td>
                        <td>
                            <% if(t.status==='done'){ %><span class="badge badge-done">Done</span>
                            <% }else{ %><span class="badge badge-pending">Pending</span><% } %>
                        </td>
                        <td class="text-zinc-500 text-[11px] whitespace-nowrap"><%= t.time %></td>
                    </tr>
                    <% }) %>
                    <% if(!transactions.length){ %>
                    <tr><td colspan="5" class="text-center py-6 text-zinc-600 text-xs">Belum ada transaksi</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ── PRODUK ── -->
<div id="pane-products" class="tab-pane">
    <div class="flex items-center justify-between mb-4">
        <div class="section-label mb-0" id="products-counter">Manajemen Produk (<%= products.length %>)</div>
        <button onclick="openAddProductModal()" class="btn-primary text-xs">
            <iconify-icon icon="mdi:plus"></iconify-icon> Tambah
        </button>
    </div>
    <div class="space-y-2.5" id="products-list">
        <% products.forEach(p => {
            const pricing = p.pricingOptions || p.items?.map(i=>({days:parseInt((i.l.match(/(\d+)/)||[])[1]||0),price:i.p})) || [];
            const minPrice = pricing.length ? Math.min(...pricing.map(o=>o.price)) : 0;
            const pricingJson = JSON.stringify(pricing).replace(/"/g,'&quot;');
        %>
        <div class="prod-card fade-in" data-product-id="<%= p.id %>">
            <div class="w-12 h-12 rounded-xl overflow-hidden flex-shrink-0 border border-white/10 bg-blue-500/10" id="prod-img-<%= p.id %>">
                <% if(p.image){ %>
                    <img src="<%= p.image %>" alt="<%= p.name %>" class="w-full h-full object-cover" loading="lazy"
                         onerror="this.style.display='none';this.parentNode.innerHTML='<div style=display:flex;align-items:center;justify-content:center;width:100%;height:100%><iconify-icon icon=\'mdi:gamepad-variant\' style=font-size:20px;color:#38bdf8></iconify-icon></div>'">
                <% }else{ %>
                    <div class="w-full h-full flex items-center justify-center">
                        <iconify-icon icon="mdi:gamepad-variant" class="text-xl text-blue-400"></iconify-icon>
                    </div>
                <% } %>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                    <span class="text-sm font-semibold text-white truncate"><%= p.name %></span>
                    <span class="badge <%= p.status==='active'?'badge-done':'badge-inactive' %>"><%= p.status==='active'?'Aktif':'Off' %></span>
                </div>
                <div class="flex items-center gap-2 text-[10px] text-zinc-500 flex-wrap">
                    <span class="px-1.5 py-0.5 rounded bg-blue-500/15 text-blue-400 font-bold uppercase"><%= p.category %></span>
                    <span class="prod-key-count <%= (p.keys?.length||0)>0?'text-emerald-400':'text-red-400' %>">
                        <iconify-icon icon="mdi:key" class="align-middle"></iconify-icon> <%= p.keys?.length||0 %> key
                    </span>
                    <span><%= p.sold||0 %> terjual</span>
                    <span class="text-zinc-500 flex items-center gap-1 flex-wrap">
                        <% pricing.forEach(po => { %>
                        <span class="px-1.5 py-0.5 rounded text-[9px] font-bold <%= (p.keys||[]).filter(k => k.endsWith(':'+po.days)).length > 0 ? 'text-emerald-400 bg-emerald-500/10' : 'text-zinc-600 bg-zinc-800/50' %>">
                            <%= po.days %>d: <%= (p.keys||[]).filter(k => k.endsWith(':'+po.days)).length %>
                        </span>
                        <% }) %>
                        <% const genericCnt = (p.keys||[]).filter(k => !k.includes(':')).length; if (genericCnt > 0) { %>
                        <span class="px-1.5 py-0.5 rounded text-[9px] font-bold text-yellow-400 bg-yellow-500/10">G: <%= genericCnt %></span>
                        <% } %>
                    </span>
                </div>
                <% if(minPrice>0){ %>
                    <div class="text-[10px] text-blue-400 font-bold mt-0.5">Mulai Rp <%= minPrice.toLocaleString('id-ID') %></div>
                <% } %>
            </div>
            <div class="flex flex-col gap-1.5 flex-shrink-0">
                <a href="/admin/product-edit?id=<%= p.id %>" class="btn-warning py-1 px-2 text-[10px] text-center">
                    <iconify-icon icon="mdi:pencil"></iconify-icon> Edit
                </a>
                <button
                    data-pid="<%= p.id %>"
                    data-name="<%= (p.name||'').replace(/\"/g,'&quot;') %>"
                    data-count="<%= p.keys?.length||0 %>"
                    onclick="openAddKeysModal(this.dataset.pid, this.dataset.name, parseInt(this.dataset.count))"
                    class="btn-success py-1 px-2 text-[10px]">
                    <iconify-icon icon="mdi:key-plus"></iconify-icon> Key
                </button>
                <button onclick="deleteProduct('<%= p.id %>')" class="btn-danger py-1 px-2 text-[10px]">
                    <iconify-icon icon="mdi:trash-can"></iconify-icon>
                </button>
            </div>
        </div>
        <% }) %>
        <% if(!products.length){ %>
        <div class="text-center py-10 text-zinc-600 text-xs">Belum ada produk. <button onclick="openAddProductModal()" class="text-blue-400 underline">Tambah sekarang</button></div>
        <% } %>
    </div>
</div>

<!-- ── TRANSAKSI ── -->
<div id="pane-transactions" class="tab-pane">
    <div class="flex items-center justify-between mb-3">
        <div class="section-label mb-0">Semua Transaksi (<%= transactions.length %>)</div>
        <div class="flex gap-2">
            <button onclick="filterTrx('all')" id="trxf-all" class="trx-filter px-2.5 py-1 rounded-lg text-[10px] font-bold bg-blue-500/20 border border-indigo-500/40 text-blue-300">Semua</button>
            <button onclick="filterTrx('pending')" id="trxf-pending" class="trx-filter px-2.5 py-1 rounded-lg text-[10px] font-bold bg-white/3 border border-white/10 text-zinc-500">Pending</button>
            <button onclick="filterTrx('done')" id="trxf-done" class="trx-filter px-2.5 py-1 rounded-lg text-[10px] font-bold bg-white/3 border border-white/10 text-zinc-500">Done</button>
        </div>
    </div>
    <div class="space-y-2" id="trx-list">
        <% transactions.forEach(t => { %>
        <div class="neon-card p-3.5 fade-in trx-item" data-trx-id="<%= t.id %>" data-status="<%= t.status %>">
            <div class="flex items-start justify-between gap-2 mb-2">
                <div>
                    <div class="flex items-center gap-2">
                        <div class="text-[11px] font-mono font-bold text-blue-400"><%= t.code %></div>
                        <% if(t.type==='reseller'){ %><span class="badge" style="background:rgba(234,179,8,.15);color:#fbbf24;border:1px solid rgba(234,179,8,.3)"><iconify-icon icon="mdi:crown" class="text-[9px]"></iconify-icon> Reseller</span><% } %>
                    </div>
                    <div class="text-sm font-semibold text-white mt-0.5"><%= t.productName %></div>
                </div>
                <% if(t.status==='done'){ %><span class="badge badge-done">Done</span>
                <% }else{ %><span class="badge badge-pending" id="trx-status-badge-<%= t.id %>">Pending</span><% } %>
                <% if(t.outOfStock && !t.key){ %><span class="badge" style="background:rgba(245,158,11,.15);color:#fbbf24;border:1px solid rgba(245,158,11,.3);">⚠ Stok Habis</span><% } %>
            </div>
            <div class="grid grid-cols-2 gap-x-4 gap-y-1 mb-3">
                <div class="text-[10px] text-zinc-500">Customer: <span class="text-zinc-300"><%= t.customerName %></span></div>
                <div class="text-[10px] text-zinc-500">WA: <span class="text-zinc-300"><%= t.wa %></span></div>
                <div class="text-[10px] text-zinc-500">Harga: <span class="text-emerald-400 font-bold">Rp <%= t.price.toLocaleString('id-ID') %></span></div>
                <div class="text-[10px] text-zinc-500">Waktu: <span class="text-zinc-300"><%= t.time %></span></div>
                <% if(t.key){ %>
                <div class="text-[10px] text-zinc-500 col-span-2">Key: <span class="text-emerald-400 font-mono font-bold"><%= t.key %></span></div>
                <% } %>
            </div>
            <div class="flex gap-2">
                <% if(t.status !== 'done'){ %>
                <button onclick="confirmTransaction('<%= t.id %>')" class="btn-success py-1 px-3 text-[10px]" id="trx-confirm-<%= t.id %>">
                    <iconify-icon icon="mdi:check-circle"></iconify-icon> Konfirmasi Bayar
                </button>
                <% } %>
                <button onclick="deleteTransaction('<%= t.id %>')" class="btn-danger py-1 px-3 text-[10px]">
                    <iconify-icon icon="mdi:trash-can"></iconify-icon>
                </button>
            </div>
        </div>
        <% }) %>
        <% if(!transactions.length){ %>
        <div class="text-center py-10 text-zinc-600 text-xs">Belum ada transaksi</div>
        <% } %>
    </div>
</div>

<!-- ── USERS ── -->
<div id="pane-users" class="tab-pane">
    <div class="flex items-center justify-between mb-3">
        <div class="section-label mb-0">Manajemen Users (<%= users.length %>)</div>
        <div class="text-[10px] text-zinc-600"><%= users.filter(u=>u.is_reseller).length %> reseller aktif</div>
    </div>
    <!-- Search user -->
    <div class="relative mb-3">
        <iconify-icon icon="mdi:magnify" class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 pointer-events-none"></iconify-icon>
        <input type="text" id="userSearchInput" oninput="filterUsers(this.value)"
            placeholder="Cari username, nomor HP, atau Gmail..."
            class="hm-input pl-8 w-full text-xs">
    </div>
    <div class="space-y-2" id="usersListContainer">
        <% users.forEach(u => { %>
        <div class="neon-card p-3.5 flex items-center gap-3 fade-in user-card"
             data-user-id="<%= u.id %>"
             data-search="<%= (u.username||'').toLowerCase() %> <%= (u.wa||'').toLowerCase() %> <%= (u.email||'').toLowerCase() %>">
            <div class="relative flex-shrink-0">
                <% if(u.photo){ %>
                    <img src="<%= u.photo %>" class="w-10 h-10 rounded-full object-cover border border-white/10">
                <% } else { %>
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-black text-sm"
                         style="background:linear-gradient(135deg,#6366f1,#6366f1)">
                        <%= u.username.charAt(0).toUpperCase() %>
                    </div>
                <% } %>
                <% if(u.is_reseller){ %>
                    <div class="absolute -top-1 -right-1 w-4 h-4 rounded-full flex items-center justify-center" style="background:#fbbf24">
                        <iconify-icon icon="mdi:crown" class="text-[8px] text-black"></iconify-icon>
                    </div>
                <% } %>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                    <div class="text-sm font-semibold text-white truncate"><%= u.username %></div>
                    <% if(u.is_reseller){ %>
                        <span class="badge" style="background:rgba(234,179,8,.15);color:#fbbf24;border:1px solid rgba(234,179,8,.3);font-size:9px">VIP</span>
                    <% } %>
                </div>
                <div class="text-[10px] text-zinc-500">WA: <%= u.wa %></div>
                <% if(u.email){ %><div class="text-[10px] text-zinc-500">Email: <%= u.email %></div><% } %>
                <% if(u.is_reseller && u.reseller_code){ %>
                    <div class="text-[10px] font-mono text-yellow-500"><%= u.reseller_code %></div>
                <% } else { %>
                    <div class="text-[10px] text-zinc-600">Bergabung: <%= new Date(u.createdAt).toLocaleDateString('id-ID') %></div>
                <% } %>
                <% if(u.is_reseller){ %>
                    <div class="text-[10px] font-bold text-emerald-400 mt-0.5">Saldo: Rp <%= (u.balance||0).toLocaleString('id-ID') %></div>
                <% } %>
            </div>
            <div class="flex flex-col gap-1.5 flex-shrink-0">
                <button onclick="toggleReseller('<%= u.id %>','<%= u.username %>')"
                    class="py-1 px-2 text-[10px] rounded-lg border transition-all font-semibold <%= u.is_reseller ? 'bg-yellow-500/15 border-yellow-500/30 text-yellow-400 hover:bg-yellow-500/25' : 'bg-white/5 border-white/15 text-zinc-400 hover:bg-blue-500/15 hover:text-blue-400 hover:border-blue-500/30' %>"
                    id="reseller-btn-<%= u.id %>">
                    <iconify-icon icon="<%= u.is_reseller ? 'mdi:crown-off' : 'mdi:crown' %>"></iconify-icon>
                    <%= u.is_reseller ? 'Cabut' : 'Jadikan' %>
                </button>
                <% if(u.is_reseller){ %>
                <button onclick="adjustBalance('<%= u.id %>','<%= u.username %>')"
                    class="py-1 px-2 text-[10px] rounded-lg border transition-all font-semibold bg-emerald-500/10 border-emerald-500/25 text-emerald-400 hover:bg-emerald-500/20">
                    <iconify-icon icon="mdi:wallet-plus"></iconify-icon> Saldo
                </button>
                <% } %>
                <button onclick="deleteUser('<%= u.id %>','<%= u.username %>')" class="btn-danger py-1 px-2 text-[10px]">
                    <iconify-icon icon="mdi:trash-can"></iconify-icon>
                </button>
            </div>
        </div>
        <% }) %>
        <% if(!users.length){ %>
        <div class="text-center py-10 text-zinc-600 text-xs">Belum ada user</div>
        <% } %>
    </div>
    <div id="userSearchEmpty" class="hidden text-center py-6 text-zinc-600 text-xs">Tidak ada user yang cocok</div>
</div>
</div>

<!-- ── TESTIMONI ── -->
<div id="pane-testimonials" class="tab-pane">
    <div class="flex items-center justify-between mb-4">
        <div class="section-label mb-0">Testimoni</div>
        <button onclick="openModal('modal-testi')" class="btn-primary text-xs">
            <iconify-icon icon="mdi:plus"></iconify-icon> Tambah
        </button>
