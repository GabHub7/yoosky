                <% if (settings.logoUrl) { %>
                <div class="mt-1.5 flex items-center gap-2">
                    <img src="<%= settings.logoUrl %>" alt="Logo preview" style="height:32px;max-width:120px;object-fit:contain;border-radius:4px;background:rgba(255,255,255,.05);padding:2px 6px;">
                    <span class="text-[10px]" style="color:var(--text-3);">Preview logo</span>
