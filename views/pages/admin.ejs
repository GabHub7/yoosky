                <input type="file" name="bannerImg" accept="image/jpeg,image/png,image/webp" class="hm-input text-xs py-2" onchange="previewBannerFile(event)">
                <div id="bannerFilePreview" class="mt-2 hidden">
                    <img id="bannerFileImg" src="" class="w-full h-28 object-cover rounded-xl border border-indigo-500/25">
                </div>
            </div>
            <div>
                <div class="setting-row-label">Atau URL gambar</div>
                <input type="text" name="imageUrl" class="hm-input" placeholder="https://..." oninput="previewBannerUrl(this.value)" id="bannerUrlInput">
            </div>
            <div id="bannerUrlPreview" class="hidden">
                <img id="bannerUrlImg" src="" class="w-full h-28 object-cover rounded-xl border border-indigo-500/25">
            </div>
            <button type="submit" id="bannerAddBtn" class="btn-primary w-full justify-center py-2.5 text-sm">
                <iconify-icon icon="mdi:plus-circle"></iconify-icon> Tambah Banner
            </button>
        </form>

        <!-- Daftar banner -->
        <div class="setting-row-label mb-3">Banner Aktif</div>
        <div id="bannerList" class="space-y-2">
            <div class="text-xs text-zinc-600 text-center py-3">Memuat...</div>
        </div>
    </div>

    <!-- QRIS Payment -->
    <div class="neon-card p-5 mb-3">
        <div class="text-xs font-bold text-blue-400 mb-4 flex items-center gap-2">
            <iconify-icon icon="mdi:qrcode-scan"></iconify-icon> Pengaturan QRIS
        </div>

        <!-- Mode Selector -->
        <div class="flex gap-2 mb-4">
            <button type="button" id="modeStaticBtn" onclick="setQrisMode('static')"
                class="flex-1 py-2.5 rounded-xl text-xs font-bold border transition-all flex items-center justify-center gap-1.5
                <%= (settings.qrisMode||'static')==='static' ? 'bg-blue-500/20 border-indigo-500/50 text-blue-300' : 'bg-white/3 border-white/10 text-zinc-500' %>">
                <iconify-icon icon="mdi:image"></iconify-icon> Statis (Gambar)
            </button>
            <button type="button" id="modeApiBtn" onclick="setQrisMode('api')"
                class="flex-1 py-2.5 rounded-xl text-xs font-bold border transition-all flex items-center justify-center gap-1.5
                <%= (settings.qrisMode||'static')==='api' ? 'bg-blue-500/20 border-indigo-500/50 text-blue-300' : 'bg-white/3 border-white/10 text-zinc-500' %>">
                <iconify-icon icon="mdi:api"></iconify-icon> API (PakKasir)
            </button>
        </div>

        <!-- QRIS Statis -->
        <div id="sectionStatic" class="<%= (settings.qrisMode||'static')==='static' ? '' : 'hidden' %>">
            <p class="text-[11px] text-zinc-500 mb-3">Upload foto QRIS dari rekening kamu (GoPay, DANA, OVO, atau QRIS Merchant). Pembayaran dikonfirmasi manual oleh admin.</p>
            <% if (settings.qrisStaticImage) { %>
            <div class="mb-3 flex flex-col items-center gap-2">
                <img src="<%= settings.qrisStaticImage %>?t=<%= Date.now() %>" class="rounded-xl border border-emerald-500/30" style="max-width:180px" id="qrisPreviewImg">
                <span class="text-[10px] text-emerald-400 flex items-center gap-1"><iconify-icon icon="mdi:check-circle"></iconify-icon> QRIS aktif</span>
            </div>
            <% } else { %>
            <div class="mb-3 p-4 rounded-xl bg-yellow-500/8 border border-yellow-500/20 text-center">
                <iconify-icon icon="mdi:alert-circle-outline" class="text-yellow-400 text-2xl mb-1 block"></iconify-icon>
                <p class="text-[11px] text-yellow-400">Belum ada gambar QRIS. Upload sekarang.</p>
            </div>
            <% } %>
            <form id="qrisStaticForm" enctype="multipart/form-data" class="space-y-2">
                <input type="file" name="qrisImage" accept="image/jpeg,image/png,image/webp" class="hm-input text-xs py-2">
                <button type="submit" class="btn-primary w-full justify-center py-2.5 text-sm">
                    <iconify-icon icon="mdi:upload"></iconify-icon> Upload Gambar QRIS
                </button>
            </form>
        </div>

        <!-- PakKasir API -->
        <div id="sectionApi" class="<%= (settings.qrisMode||'static')==='api' ? '' : 'hidden' %> space-y-3">
            <div class="p-3 rounded-xl bg-red-500/8 border border-red-500/20 text-[11px] text-red-400 mb-2">
                <iconify-icon icon="mdi:alert"></iconify-icon> Pastikan API key dan URL yang dimasukkan sudah benar. Test koneksi sebelum menyimpan.
            </div>
            <form id="pakasirForm" class="space-y-3">
                <div>
                    <div class="setting-row-label">API Key</div>
                    <input type="text" name="apiKey" value="<%= settings.pakasir?.apiKey||'' %>" class="hm-input font-mono text-xs" placeholder="masukkan API key PakKasir">
                </div>
                <div>
                    <div class="setting-row-label">Project Name</div>
                    <input type="text" name="project" value="<%= settings.pakasir?.project||'' %>" class="hm-input" placeholder="nama project kamu">
                </div>
                <div>
                    <div class="setting-row-label">API Base URL <span class="text-zinc-600 font-normal">(hostname, tanpa https://)</span></div>
                    <input type="text" name="apiBaseUrl" value="<%= settings.pakasir?.apiBaseUrl||'api.pakasir.com' %>" class="hm-input font-mono text-xs" placeholder="api.pakasir.com">
                </div>
                <button type="button" onclick="testPakasir()" class="w-full py-2 rounded-xl text-xs font-bold text-zinc-400 border border-white/10 bg-white/3 hover:bg-white/8 transition-all flex items-center justify-center gap-1.5">
                    <iconify-icon icon="mdi:wifi-check"></iconify-icon> Test Koneksi API
                </button>
                <div id="testResult" class="hidden text-[11px] p-2.5 rounded-lg"></div>
                <button type="submit" class="btn-primary w-full justify-center py-2.5 text-sm">
                    <iconify-icon icon="mdi:content-save"></iconify-icon> Simpan Pengaturan API
                </button>
            </form>
        </div>

        <!-- Simpan Mode -->
        <input type="hidden" id="qrisModeVal" value="<%= settings.qrisMode||'static' %>">
    </div>

    <!-- Reseller VIP -->
    <div class="neon-card p-5 mb-3" style="border-color:rgba(234,179,8,.2)">
        <div class="text-xs font-bold mb-4 flex items-center gap-2" style="color:#fbbf24">
            <iconify-icon icon="mdi:crown"></iconify-icon> Program Reseller VIP
        </div>
        <form id="resellerSettingsForm" class="space-y-3">
            <div class="flex items-center justify-between p-3 rounded-xl" style="background:rgba(234,179,8,.06);border:1px solid rgba(234,179,8,.15)">
                <div>
                    <div class="text-xs font-semibold text-white">Aktifkan Program Reseller</div>
                    <div class="text-[10px] text-zinc-500 mt-0.5">Tampilkan banner upgrade reseller di halaman utama</div>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" name="resellerEnabled" id="resellerEnabledToggle" class="sr-only peer" <%= (settings.resellerEnabled !== false) ? 'checked' : '' %>>
                    <div class="w-9 h-5 bg-zinc-700 peer-focus:ring-2 peer-focus:ring-yellow-500/30 rounded-full peer peer-checked:bg-yellow-500 transition-all after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"></div>
                </label>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <div class="setting-row-label">Biaya Upgrade (Rp)</div>
                    <input type="number" name="resellerPrice" value="<%= settings.resellerPrice || 50000 %>" min="1000" class="hm-input" placeholder="50000">
                </div>
                <div>
                    <div class="setting-row-label">Diskon Reseller (%)</div>
                    <input type="number" name="resellerDiscount" value="<%= settings.resellerDiscount || 20 %>" min="1" max="99" class="hm-input" placeholder="20">
                </div>
            </div>
            <div>
                <div class="setting-row-label">Minimal Top Up Saldo (Rp)</div>
                <input type="number" name="resellerMinDeposit" value="<%= settings.resellerMinDeposit || 50000 %>" min="1000" class="hm-input" placeholder="50000">
                <div class="text-[10px] text-zinc-500 mt-1">Nominal minimum saat reseller top up saldo wallet untuk beli key tanpa scan QRIS berulang.</div>
            </div>
            <div>
                <div class="setting-row-label">Catatan / Tagline</div>
                <input type="text" name="resellerNote" value="<%= settings.resellerNote || 'Dapatkan diskon eksklusif untuk semua produk!' %>" class="hm-input">
            </div>
            <div class="p-3 rounded-xl text-[11px]" style="background:rgba(234,179,8,.06);border:1px solid rgba(234,179,8,.12);color:#a1a1aa">
                <iconify-icon icon="mdi:information-outline" class="text-yellow-400 align-middle mr-1"></iconify-icon>
                Preview: User hemat <strong class="text-yellow-400" id="discPreview"><%= settings.resellerDiscount || 20 %>%</strong> otomatis di semua produk saat login sebagai reseller.
            </div>
            <button type="submit" class="w-full py-2.5 rounded-xl text-xs font-black flex items-center justify-center gap-2" style="background:linear-gradient(135deg,#d97706,#fbbf24);color:#000">
                <iconify-icon icon="mdi:crown"></iconify-icon> Simpan Pengaturan Reseller
            </button>
        </form>
    </div>

    <!-- Kredensial Admin -->
    <div class="neon-card p-5 mb-3">
        <div class="text-xs font-bold text-red-400 mb-4 flex items-center gap-2">
            <iconify-icon icon="mdi:shield-account"></iconify-icon> Kredensial Admin
        </div>
        <form id="credForm" class="space-y-3">
            <div>
                <div class="setting-row-label">Username Admin Baru</div>
                <input type="text" name="adminUsername" value="<%= settings.adminUsername %>" class="hm-input">
            </div>
            <div>
                <div class="setting-row-label">Password Baru</div>
                <input type="password" name="newPassword" class="hm-input" placeholder="Kosongkan jika tidak ingin ubah">
            </div>
            <button type="submit" class="btn-danger w-full justify-center py-2.5 text-sm">
                <iconify-icon icon="mdi:shield-key"></iconify-icon> Update Kredensial
            </button>
        </form>
    </div>

    <!-- Export / Import Data -->
    <div class="neon-card p-5 mb-3">
        <div class="text-xs font-bold text-blue-400 mb-4 flex items-center gap-2">
            <iconify-icon icon="mdi:database-sync"></iconify-icon> Backup & Restore Database
        </div>
        <p class="text-[11px] text-zinc-500 mb-4">Download semua data (produk, transaksi, user, dll) sebagai file JSON. Berguna untuk backup atau pindah server.</p>
        <div class="grid grid-cols-2 gap-3">
            <a href="/admin/export" target="_blank"
               class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-xs font-bold transition-all hover:scale-[1.02]"
               style="background:linear-gradient(135deg,rgba(37,99,235,.15),rgba(37,99,235,.08));border:1px solid rgba(37,99,235,.3);color:#38bdf8;">
                <iconify-icon icon="mdi:download"></iconify-icon> Export Database
            </a>
            <div>
                <button onclick="document.getElementById('importInput').click()"
                    class="w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-xs font-bold transition-all hover:scale-[1.02]"
                    style="background:linear-gradient(135deg,rgba(234,179,8,.15),rgba(245,158,11,.08));border:1px solid rgba(234,179,8,.3);color:#fbbf24;">
                    <iconify-icon icon="mdi:upload"></iconify-icon> Import Database
                </button>
                <input type="file" id="importInput" accept=".json" class="hidden" onchange="importDB(event)">
            </div>
        </div>
        <div id="importStatus" class="mt-3 hidden"></div>
    </div>
</div>

</div><!-- /max-w -->

