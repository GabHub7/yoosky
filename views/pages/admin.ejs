document.getElementById('categoryForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const fd = new FormData(this);
    const raw = fd.get('categories') || '';
    const lines = raw.trim().split('\n').filter(l=>l.trim());
    const cats = [], labels = {};
    lines.forEach(line => {
        const [id, ...rest] = line.split(':');
        if (id && id.trim()) { cats.push(id.trim()); labels[id.trim()] = rest.join(':').trim()||id.trim(); }
    });
    if (!cats.length) { toast('Minimal 1 kategori diperlukan', 'error'); return; }
    const d = await api('/admin/settings/update', { categories: JSON.stringify(cats), categoryLabels: JSON.stringify(labels) });
    if (d.success) { toast('Kategori disimpan!', 'success'); setTimeout(()=>window.location.href='/admin#settings',800); }
    else toast(d.message, 'error');
});

