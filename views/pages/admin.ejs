    renderVouchers(d.data || []);
}

function renderVouchers(vouchers) {
    const list = document.getElementById('vouchersList');
    const stats = document.getElementById('voucherStatsLabel');
    if (!list) return;
    const active = vouchers.filter(v => v.active).length;
    if (stats) stats.textContent = `${vouchers.length} total · ${active} aktif`;
    if (!vouchers.length) {
        list.innerHTML = '<div class="text-center py-8 text-zinc-600 text-xs"><iconify-icon icon="mdi:ticket-outline" class="text-3xl block mx-auto mb-2 text-zinc-700"></iconify-icon>Belum ada voucher</div>';
        return;
    }
    list.innerHTML = vouchers.map(v => {
        const expired = v.expiresAt && new Date(v.expiresAt) < new Date();
        const exhausted = v.maxUses > 0 && v.usedCount >= v.maxUses;
        const isInactive = !v.active || expired || exhausted;
        const valDisplay = v.type === 'percent' ? v.value + '%' : 'Rp ' + v.value.toLocaleString('id-ID');
        const minDisplay = v.minPurchase > 0 ? 'Min Rp ' + v.minPurchase.toLocaleString('id-ID') : 'Tanpa min';
        return `<div class="neon-card p-3 flex items-center gap-3 ${isInactive ? 'opacity-50' : ''}">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 ${v.active ? 'bg-green-500/15 border border-green-500/25' : 'bg-zinc-800'}">
                <iconify-icon icon="${v.active ? 'mdi:ticket-percent' : 'mdi:ticket-off'}" class="text-lg ${v.active ? 'text-green-400' : 'text-zinc-600'}"></iconify-icon>
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="font-mono text-sm font-black text-white">${v.code}</span>
                    <span class="text-[10px] font-bold px-2 py-0.5 rounded ${v.active ? 'bg-green-500/20 text-green-400 border border-green-500/30' : 'bg-zinc-700 text-zinc-500'}">${valDisplay}</span>
                    ${v.excludeReseller ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded" style="background:rgba(234,179,8,.12);color:#fbbf24;border:1px solid rgba(234,179,8,.25)">Non-Reseller</span>' : ''}
                </div>
                <div class="flex items-center gap-3 text-[10px] mt-0.5 flex-wrap">
                    <span class="text-zinc-500">${v.description || '—'}</span>
                    <span class="text-zinc-600">${minDisplay}</span>
                    <span class="text-zinc-600">${v.usedCount}/${v.maxUses || '∞'} dipakai</span>
                </div>
                ${v.expiresAt ? `<div class="text-[9px] ${expired ? 'text-red-400' : 'text-zinc-500'}">Kadaluarsa: ${new Date(v.expiresAt).toLocaleDateString('id-ID')}</div>` : ''}
            </div>
            <div class="flex flex-col gap-1">
                <button onclick="toggleVoucher('${v.id}')" class="px-2 py-1 text-[10px] rounded-lg border transition-all font-semibold ${v.active ? 'bg-yellow-500/15 border-yellow-500/30 text-yellow-400 hover:bg-yellow-500/25' : 'bg-emerald-500/15 border-emerald-500/30 text-emerald-400 hover:bg-emerald-500/25'}">
                    <iconify-icon icon="${v.active ? 'mdi:pause' : 'mdi:play'}"></iconify-icon>
                    ${v.active ? 'Nonaktif' : 'Aktifkan'}
                </button>
                <button onclick="deleteVoucher('${v.id}')" class="btn-danger py-1 px-2 text-[10px]">
                    <iconify-icon icon="mdi:trash-can"></iconify-icon>
                </button>
            </div>
        </div>`;
    }).join('');
}

async function addVoucher() {
    const code = document.getElementById('newVoucherCode').value.trim();
    const type = document.getElementById('newVoucherType').value;
    const value = document.getElementById('newVoucherValue').value;
    const minPurchase = document.getElementById('newVoucherMin').value;
    const maxUses = document.getElementById('newVoucherMax').value;
    const perUserLimit = document.getElementById('newVoucherPerUser').value;
    const expiresAt = document.getElementById('newVoucherExpiry').value;
    const description = document.getElementById('newVoucherDesc').value.trim();
    if (!code || !value) { toast('Kode dan nilai wajib diisi', 'error'); return; }
    const d = await api('/admin/vouchers/add', { code, type, value, minPurchase, maxUses, perUserLimit, expiresAt, description, excludeReseller: document.getElementById('newVoucherExcludeReseller').checked });
    if (d.success) {
        toast('Voucher berhasil dibuat!', 'success');
        document.getElementById('newVoucherCode').value = '';
        document.getElementById('newVoucherValue').value = '';
        document.getElementById('newVoucherDesc').value = '';
        renderVouchers(d.data);
    } else toast(d.message, 'error');
}

async function toggleVoucher(id) {
    const d = await api('/admin/vouchers/toggle/' + id, {});
    if (d.success) loadVouchers();
    else toast(d.message, 'error');
}

async function deleteVoucher(id) {
    if (!confirm('Hapus voucher ini?')) return;
    const d = await api('/admin/vouchers/delete/' + id, {});
    if (d.success) {
        toast('Voucher dihapus', 'success');
        loadVouchers();
    } else toast(d.message, 'error');
}

// ═══ EXPORT / IMPORT DATABASE ═══
async function importDB(event) {
    const file = event.target.files[0];
    const statusEl = document.getElementById('importStatus');
    if (!file) return;
    statusEl.classList.remove('hidden');
    statusEl.innerHTML = '<div class="flex items-center gap-2 text-xs text-blue-400"><iconify-icon icon="mdi:loading" class="animate-spin"></iconify-icon> Membaca file...</div>';
    try {
        const text = await file.text();
        const data = JSON.parse(text);
        const r = await fetch('/admin/import', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const d = await r.json();
        if (d.success) {
            statusEl.innerHTML = `<div class="flex items-center gap-2 text-xs text-emerald-400"><iconify-icon icon="mdi:check-circle"></iconify-icon> ${d.message}. Reload...</div>`;
            setTimeout(() => location.reload(), 1000);
        } else {
            statusEl.innerHTML = `<div class="flex items-center gap-2 text-xs text-red-400"><iconify-icon icon="mdi:alert-circle"></iconify-icon> ${d.message}</div>`;
        }
    } catch(e) {
        statusEl.innerHTML = `<div class="flex items-center gap-2 text-xs text-red-400"><iconify-icon icon="mdi:alert-circle"></iconify-icon> File tidak valid: ${e.message}</div>`;
    }
    event.target.value = '';
}
</script>
