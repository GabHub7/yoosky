    </div>

    <!-- BANNER CAROUSEL -->
    <div class="neon-card p-5 mb-3">
        <div class="text-xs font-bold text-blue-400 mb-4 flex items-center gap-2">
            <iconify-icon icon="mdi:image-multiple"></iconify-icon> Banner Carousel
        </div>

        <!-- Form tambah banner -->
        <form id="bannerAddForm" enctype="multipart/form-data" class="space-y-3 mb-5" onsubmit="addBanner(event)">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div>
                    <div class="setting-row-label">Judul Banner (opsional)</div>
                    <input type="text" name="title" class="hm-input" placeholder="Contoh: PROMO SPESIAL">
                </div>
                <div>
                    <div class="setting-row-label">Subjudul (opsional)</div>
                    <input type="text" name="subtitle" class="hm-input" placeholder="Contoh: Diskon 20% hari ini">
