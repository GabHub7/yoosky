<%
const pageTitle = 'Leaderboard';
%>
<style>
.podium-wrap{display:flex;align-items:flex-end;justify-content:center;gap:12px;padding:0 8px;}
.rank-item{display:flex;flex-direction:column;align-items:center;flex:1;max-width:140px;}
.avatar-ring{position:relative;margin-bottom:12px;display:flex;align-items:center;justify-content:center;}
.avatar-inner{border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Orbitron',sans-serif;font-weight:900;color:#fff;position:relative;z-index:1;border:3px solid;}
.rank-1 .avatar-inner{width:80px;height:80px;font-size:28px;background:linear-gradient(135deg,#fbbf24,#f59e0b);border-color:#fbbf24;box-shadow:0 0 0 4px rgba(251,191,36,.2),0 0 40px rgba(251,191,36,.5);animation:pulseGold 2s ease-in-out infinite;}
.rank-2 .avatar-inner{width:62px;height:62px;font-size:22px;background:linear-gradient(135deg,#94a3b8,#64748b);border-color:#94a3b8;box-shadow:0 0 0 3px rgba(148,163,184,.2),0 0 20px rgba(148,163,184,.3);}
.rank-3 .avatar-inner{width:62px;height:62px;font-size:22px;background:linear-gradient(135deg,#fb923c,#ea580c);border-color:#fb923c;box-shadow:0 0 0 3px rgba(251,146,60,.2),0 0 20px rgba(251,146,60,.3);}
.crown-wrap{position:absolute;top:-24px;left:50%;transform:translateX(-50%);display:flex;align-items:center;justify-content:center;}
.crown-wrap iconify-icon{font-size:22px;color:#fbbf24;/* drop-shadow removed:  rgba(251,191,36,.9));animation:floatCrown 2.5s ease-in-out infinite;}
@keyframes pulseGold{0%,100%{box-shadow:0 0 0 4px rgba(251,191,36,.2),0 0 40px rgba(251,191,36,.5);transform:scale(1);}50%{box-shadow:0 0 0 8px rgba(251,191,36,.1),0 0 60px rgba(251,191,36,.7);transform:scale(1.04);}}
@keyframes floatCrown{0%,100%{transform:translateX(-50%) translateY(0) rotate(-6deg);}50%{transform:translateX(-50%) translateY(-7px) rotate(6deg);}}
.podium-base{width:100%;border-radius:14px 14px 0 0;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:14px 8px 16px;position:relative;overflow:hidden;}
.podium-base::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.04) 0%,transparent 100%);}
.rank-1 .podium-base{height:130px;background:linear-gradient(135deg,rgba(251,191,36,.18),rgba(245,158,11,.08));border:1.5px solid rgba(251,191,36,.35);box-shadow:0 0 30px rgba(251,191,36,.15);}
.rank-2 .podium-base{height:100px;background:linear-gradient(135deg,rgba(148,163,184,.14),rgba(100,116,139,.06));border:1.5px solid rgba(148,163,184,.3);}
.rank-3 .podium-base{height:100px;background:linear-gradient(135deg,rgba(251,146,60,.14),rgba(234,88,12,.06));border:1.5px solid rgba(251,146,60,.3);}
.pbadge{position:absolute;top:6px;right:8px;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Orbitron',sans-serif;font-size:10px;font-weight:900;}
.pb1{background:linear-gradient(135deg,#fbbf24,#d97706);color:#000;}
.pb2{background:linear-gradient(135deg,#94a3b8,#475569);color:#fff;}
.pb3{background:linear-gradient(135deg,#fb923c,#c2410c);color:#fff;}
.pnum{font-family:'Orbitron',sans-serif;font-weight:900;font-size:34px;line-height:1;margin-bottom:6px;opacity:.22;position:relative;z-index:1;}
.rank-1 .pnum{color:#fbbf24;}.rank-2 .pnum{color:#94a3b8;}.rank-3 .pnum{color:#fb923c;}
.pname{font-size:12px;font-weight:800;text-align:center;line-height:1.2;word-break:break-all;position:relative;z-index:1;}
.rank-1 .pname{font-size:14px;background:linear-gradient(135deg,#fbbf24,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.rank-2 .pname{color:#cbd5e1;}.rank-3 .pname{color:#fdba74;}
.pstat{font-size:10px;text-align:center;margin-top:4px;position:relative;z-index:1;}
.rank-1 .pstat{color:rgba(251,191,36,.85);font-weight:700;}.rank-2 .pstat{color:rgba(148,163,184,.7);}.rank-3 .pstat{color:rgba(251,146,60,.7);}
.rank-row{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:13px 16px;display:flex;align-items:center;gap:14px;transition:all .25s;position:relative;overflow:hidden;}
.rank-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(180deg,#1e40af,#3b82f6);opacity:0;transition:opacity .25s;border-radius:0 2px 2px 0;}
.rank-row:hover{border-color:rgba(37,99,235,.4);background:rgba(37,99,235,.08);}
.rank-row:hover::before{opacity:1;}
.rank-item.rank-1{animation:fadeInUp .5s ease-out both;animation-delay:.1s;}
.rank-item.rank-2{animation:fadeInUp .5s ease-out both;animation-delay:.2s;}
.rank-item.rank-3{animation:fadeInUp .5s ease-out both;animation-delay:.3s;}
.rank-row{animation:fadeInUp .5s ease-out both;}
.rank-row:nth-child(1){animation-delay:.4s;}
.rank-row:nth-child(2){animation-delay:.45s;}
.rank-row:nth-child(3){animation-delay:.5s;}
.rank-row:nth-child(n+4){animation-delay:.55s;}
.rnbadge{width:36px;height:36px;border-radius:10px;background:rgba(37,99,235,.12);border:1px solid rgba(37,99,235,.2);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',sans-serif;font-size:13px;font-weight:900;color:#38bdf8;flex-shrink:0;}
.ravatar{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:17px;color:#fff;flex-shrink:0;}
.trxcount{font-family:'Orbitron',sans-serif;font-size:20px;font-weight:900;background:linear-gradient(135deg,#38bdf8,#93c5fd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;flex-shrink:0;}
</style>

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-[#0d0d20]/95 backdrop-blur-md border-b border-white/5 transition-all duration-300">
    <div class="max-w-4xl mx-auto px-4">
        <div class="flex items-center justify-between h-14">
            <a href="/" class="flex items-center gap-2.5">
                <% if (settings?.logoUrl) { %>
                <img src="<%= settings.logoUrl %>" alt="Logo" class="h-9 w-auto object-contain" style="max-width:40px;">
                <% } else { %>
                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:#3b82f6;">
                    <iconify-icon icon="mdi:store" style="color:#fff;font-size:18px;"></iconify-icon>
                </div>
                <% } %>
                <span class="font-bold text-base font-black shimmer-text"><%= settings.siteName || 'YOOSKY STORE' %></span>
            </a>
            <a href="/" class="flex items-center gap-1.5 text-xs text-zinc-400 hover:text-white transition-colors px-3 py-1.5 rounded-lg border border-white/10 hover:bg-white/5">
                <iconify-icon icon="mdi:arrow-left" class="text-sm"></iconify-icon> Kembali
            </a>
        </div>
    </div>
</nav>

<div class="min-h-screen pt-14 pb-10">
    <!-- HERO -->
    <div class="relative overflow-hidden" style="background:linear-gradient(135deg,rgba(37,99,235,.1),rgba(37,99,235,.07),rgba(251,191,36,.05));">
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-0 left-1/4 w-64 h-64 rounded-full" style="background:radial-gradient(circle,rgba(251,191,36,.1) 0%,transparent 70%);"></div>
            <div class="absolute top-0 right-1/3 w-48 h-48 rounded-full" style="background:radial-gradient(circle,rgba(37,99,235,.1) 0%,transparent 70%);"></div>
        </div>
        <div class="max-w-4xl mx-auto px-4 py-10 text-center relative">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-yellow-500/25 bg-yellow-500/8 mb-4">
                <iconify-icon icon="mdi:trophy-award" class="text-yellow-400 text-sm"></iconify-icon>
                <span class="text-[10px] font-black text-yellow-300 uppercase tracking-widest">Hall of Fame</span>
            </div>
            <h1 class="font-bold text-3xl sm:text-4xl font-black text-white mb-2 leading-tight">
                TOP <span class="shimmer-text">BUYERS</span>
            </h1>
            <p class="text-sm text-zinc-500 max-w-xs mx-auto">Pembeli terbaik berdasarkan total transaksi sukses</p>
            <div class="flex items-center justify-center gap-6 mt-6">
                <div class="text-center">
                    <div class="text-xl font-black font-bold text-white"><%= leaderboard.length %></div>
                    <div class="text-[10px] text-zinc-600 mt-0.5">Total Pembeli</div>
                </div>
                <div class="w-px h-8 bg-white/10"></div>
                <div class="text-center">
                    <div class="text-xl font-black font-bold" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                        <%= leaderboard[0] ? leaderboard[0].totalTransactions : 0 %>
                    </div>
                    <div class="text-[10px] text-zinc-600 mt-0.5">Transaksi Terbanyak</div>
                </div>
                <div class="w-px h-8 bg-white/10"></div>
                <div class="text-center">
                    <div class="text-xl font-black font-bold" style="background:linear-gradient(135deg,#34d399,#10b981);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                        <%= leaderboard.reduce((s,i)=>s+i.totalTransactions,0) %>
                    </div>
                    <div class="text-[10px] text-zinc-600 mt-0.5">Total Transaksi</div>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 mt-8 space-y-8">

        <% if (leaderboard.length === 0) { %>
        <div class="text-center py-20">
            <div class="w-16 h-16 rounded-2xl bg-zinc-800/50 border border-white/5 flex items-center justify-center mx-auto mb-4">
                <iconify-icon icon="mdi:trophy-outline" class="text-4xl text-zinc-700"></iconify-icon>
            </div>
            <p class="text-sm text-zinc-500">Belum ada data leaderboard</p>
            <p class="text-xs text-zinc-700 mt-1">Jadilah yang pertama bertransaksi!</p>
        </div>
        <% } %>

        <!-- PODIUM -->
        <% if (leaderboard.length >= 1) { %>
        <div>
            <div class="flex items-center gap-2 mb-6">
                <div class="w-7 h-7 rounded-lg bg-yellow-500/15 border border-yellow-500/25 flex items-center justify-center">
                    <iconify-icon icon="mdi:podium-gold" class="text-yellow-400 text-base"></iconify-icon>
                </div>
                <span class="text-sm font-black text-white uppercase tracking-wider">Podium Teratas</span>
            </div>
            <div class="podium-wrap">
                <!-- Rank 2 -->
                <% if (leaderboard[1]) { %>
                <div class="rank-item rank-2 fade-in-up">
                    <div class="avatar-ring mb-3"><div class="avatar-inner"><% if(leaderboard[1].photo){%><img src="<%= leaderboard[1].photo %>" class="user-avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%"><%}else{%><%= leaderboard[1].username.charAt(0).toUpperCase() %><%}%></div></div>
                    <div class="podium-base">
                        <div class="pbadge pb2">2</div>
                        <div class="pnum">2</div>
                        <div class="pname"><%= leaderboard[1].username %></div>
                        <div class="pstat"><iconify-icon icon="mdi:receipt-text-check" style="font-size:10px;vertical-align:middle"></iconify-icon> <%= leaderboard[1].totalTransactions %> trx</div>
                    </div>
                </div>
                <% } else { %>
                <div class="rank-item rank-2" style="opacity:.15">
                    <div class="avatar-ring mb-3"><div class="avatar-inner">?</div></div>
                    <div class="podium-base"><div class="pnum">2</div></div>
                </div>
                <% } %>

                <!-- Rank 1 -->
                <div class="rank-item rank-1 fade-in-up">
                    <div class="avatar-ring mb-3">
                        <div class="crown-wrap"><iconify-icon icon="mdi:crown"></iconify-icon></div>
                        <div class="avatar-inner"><% if(leaderboard[0].photo){%><img src="<%= leaderboard[0].photo %>" class="user-avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%"><%}else{%><%= leaderboard[0].username.charAt(0).toUpperCase() %><%}%></div>
                    </div>
                    <div class="podium-base">
                        <div class="pbadge pb1">1</div>
                        <div class="pnum">1</div>
                        <div class="pname"><%= leaderboard[0].username %></div>
                        <div class="pstat"><iconify-icon icon="mdi:receipt-text-check" style="font-size:11px;vertical-align:middle"></iconify-icon> <%= leaderboard[0].totalTransactions %> trx</div>
                        <div class="pstat" style="font-size:9px;opacity:.65;margin-top:2px">Rp <%= leaderboard[0].totalSpent.toLocaleString('id-ID') %></div>
                    </div>
                </div>

                <!-- Rank 3 -->
                <% if (leaderboard[2]) { %>
                <div class="rank-item rank-3 fade-in-up">
                    <div class="avatar-ring mb-3"><div class="avatar-inner"><% if(leaderboard[2].photo){%><img src="<%= leaderboard[2].photo %>" class="user-avatar" style="width:100%;height:100%;object-fit:cover;border-radius:50%"><%}else{%><%= leaderboard[2].username.charAt(0).toUpperCase() %><%}%></div></div>
                    <div class="podium-base">
                        <div class="pbadge pb3">3</div>
                        <div class="pnum">3</div>
                        <div class="pname"><%= leaderboard[2].username %></div>
                        <div class="pstat"><iconify-icon icon="mdi:receipt-text-check" style="font-size:10px;vertical-align:middle"></iconify-icon> <%= leaderboard[2].totalTransactions %> trx</div>
                    </div>
                </div>
                <% } else { %>
                <div class="rank-item rank-3" style="opacity:.15">
                    <div class="avatar-ring mb-3"><div class="avatar-inner">?</div></div>
                    <div class="podium-base"><div class="pnum">3</div></div>
                </div>
                <% } %>
            </div>
        </div>
        <% } %>

        <!-- RANK 4+ -->
        <% if (leaderboard.length > 3) { %>
        <div>
            <div class="flex items-center gap-2 mb-4">
                <div class="w-7 h-7 rounded-lg bg-blue-500/15 border border-indigo-500/25 flex items-center justify-center">
                    <iconify-icon icon="mdi:format-list-numbered" class="text-blue-400 text-base"></iconify-icon>
                </div>
                <span class="text-sm font-black text-white uppercase tracking-wider">Peringkat Lainnya</span>
            </div>
            <div class="space-y-2.5">
                <% const palettes=['from-blue-600 to-indigo-700','from-blue-500 to-cyan-600','from-blue-500 to-indigo-600','from-emerald-500 to-teal-600','from-orange-500 to-red-500']; %>
                <% leaderboard.slice(3).forEach((item, idx) => { %>
                <div class="rank-row fade-in-up">
                    <div class="rnbadge">#<%= item.rank %></div>
                    <% if(item.photo){ %><div class="ravatar overflow-hidden" style="border:2px solid rgba(255,255,255,.1)"><img src="<%= item.photo %>" class="user-avatar" style="width:42px;height:42px;"></div><% } else { %><div class="ravatar bg-gradient-to-br <%= palettes[idx % palettes.length] %>"><%= item.username.charAt(0).toUpperCase() %></div><% } %>
                    <div class="flex-1 min-w-0">
                        <div class="text-sm font-bold text-white truncate"><%= item.username %></div>
                        <div class="flex items-center gap-3 mt-0.5">
                            <span class="text-[10px] text-zinc-500 flex items-center gap-1">
                                <iconify-icon icon="mdi:receipt-text-check" class="text-emerald-400" style="font-size:10px"></iconify-icon>
                                <%= item.totalTransactions %> transaksi
                            </span>
                            <span class="text-[10px] text-zinc-600">Rp <%= item.totalSpent.toLocaleString('id-ID') %></span>
                        </div>
                    </div>
                    <div class="trxcount"><%= item.totalTransactions %></div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- CTA -->
        <div class="neon-card p-6 text-center">
            <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-indigo-500/20 to-blue-600/20 border border-blue-500/20 flex items-center justify-center mx-auto mb-3">
                <iconify-icon icon="mdi:crown-outline" class="text-2xl text-blue-400"></iconify-icon>
            </div>
            <h3 class="text-base font-black text-white mb-1">Masuk ke Leaderboard!</h3>
            <p class="text-xs text-zinc-500 mb-4 max-w-xs mx-auto">Lakukan transaksi dan jadilah salah satu pembeli terbaik kami</p>
            <a href="/" class="btn-gaming inline-flex items-center gap-2 px-6 py-3 text-sm font-bold rounded-xl">
                <iconify-icon icon="mdi:shopping" class="text-base"></iconify-icon>
                Belanja Sekarang
            </a>
        </div>

    </div>
</div>

<footer class="py-5 text-center border-t border-white/5">
    <p class="text-[11px] text-zinc-700">&copy; 2026 <span class="text-zinc-500 font-semibold"><%= settings.siteName %></span> — All rights reserved</p>
</footer>
