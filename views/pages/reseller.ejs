<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<link rel="icon" type="image/png" href="data:image/png;base64,">
<title>Reseller VIP — <%= settings.siteName %></title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" defer></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{height:100%;width:100%;max-width:100%;overflow-x:hidden;background:#0a0f1e;}
:root{
    --bg-main:#0a0f1e;
    --bg-card:#111827;
    --bg-hover:#1a2235;
    --border:rgba(255,255,255,0.07);
    --border-md:rgba(255,255,255,0.12);
    --blue:#3b82f6;
    --blue-dim:rgba(59,130,246,0.12);
    --green:#22c55e;
    --text-1:#f1f5f9;
    --text-2:#94a3b8;
    --text-3:#475569;
}
body{font-family:'Inter',sans-serif;background:var(--bg-main);color:var(--text-1);min-height:100dvh;width:100%;max-width:100%;overflow-x:hidden;position:relative;padding-bottom:40px;-webkit-font-smoothing:antialiased;}
@keyframes fadeInUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes slideInBottom{from{transform:translateY(100%);opacity:0}to{transform:translateY(0);opacity:1}}
.fade-in-up{animation:fadeInUp .3s ease-out both;}
.animate-spin{animation:spin 1s linear infinite;}
.card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;}
.hm-input{width:100%;padding:10px 14px;border-radius:8px;background:rgba(255,255,255,.04);border:1px solid var(--border-md);color:var(--text-1);font-size:13px;transition:border-color .15s;font-family:'Inter',sans-serif;}
.hm-input:focus{outline:none;border-color:rgba(59,130,246,.5);background:rgba(59,130,246,.05);}
.benefit-row{display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);}
.benefit-row:last-child{border-bottom:none;}
.btn-primary{display:inline-flex;align-items:center;justify-content:center;gap:6px;background:var(--blue);color:#fff;font-weight:700;font-size:13px;border-radius:8px;cursor:pointer;border:none;transition:opacity .15s;}
.btn-primary:hover{opacity:.88;}
.btn-primary:active{opacity:.7;transform:scale(.97);}
#toast-wrap{position:fixed;top:14px;right:14px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast-item{padding:10px 14px;border-radius:10px;background:var(--bg-card);font-size:12px;max-width:280px;border:1px solid var(--border-md);color:var(--text-1);}
.toast-success{border-color:rgba(34,197,94,.35);color:#4ade80;}
.toast-error{border-color:rgba(239,68,68,.35);color:#f87171;}
</style>
</head>
<body>
<div id="toast-wrap"></div>

<!-- NAVBAR -->
<nav style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(10,15,30,.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);">
    <div style="max-width:640px;margin:0 auto;padding:0 16px;">
        <div style="display:flex;align-items:center;justify-content:space-between;height:56px;">
            <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
                <% if (settings?.logoUrl) { %>
                <img src="<%= settings.logoUrl %>" alt="Logo" style="height:30px;width:auto;object-fit:contain;max-width:36px;flex-shrink:0;">
                <% } else { %>
                <div style="width:30px;height:30px;border-radius:8px;background:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <iconify-icon icon="mdi:store" style="color:#fff;font-size:16px;"></iconify-icon>
                </div>
                <% } %>
                <span style="font-family:'Inter',sans-serif;font-weight:900;font-size:15px;color:#ffffff;letter-spacing:.01em;line-height:1;"><%= settings.siteName %></span>
            </a>
            <a href="/" style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-2);padding:6px 12px;border-radius:8px;border:1px solid var(--border);text-decoration:none;" onmouseover="this.style.color='var(--text-1)';this.style.background='rgba(255,255,255,.04)'" onmouseout="this.style.color='var(--text-2)';this.style.background='transparent'">
                <iconify-icon icon="mdi:arrow-left" style="font-size:14px;"></iconify-icon> Kembali
            </a>
        </div>
    </div>
</nav>

<div style="min-height:100dvh;padding-top:64px;padding-bottom:40px;padding-left:16px;padding-right:16px;">
<div style="max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:12px;">

<!-- ── HERO ── -->
<div class="card fade-in-up" style="margin-top:16px;border-color:rgba(59,130,246,.25);">
    <div style="height:3px;background:var(--blue);border-radius:12px 12px 0 0;"></div>
    <div style="padding:24px;text-align:center;">
        <div style="width:56px;height:56px;border-radius:14px;background:var(--blue-dim);border:1px solid rgba(59,130,246,.3);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
            <iconify-icon icon="mdi:crown" style="color:var(--blue);font-size:26px;"></iconify-icon>
        </div>
        <div style="font-size:16px;font-weight:800;color:var(--text-1);letter-spacing:.02em;margin-bottom:8px;">RESELLER VIP</div>
        <p style="font-size:13px;color:var(--text-2);line-height:1.6;max-width:320px;margin:0 auto;">
            <%= settings.resellerNote || 'Bergabung dan nikmati harga eksklusif untuk semua produk.' %>
        </p>
    </div>
</div>

<% if (user && user.is_reseller) { %>
<!-- ── SUDAH RESELLER ── -->
<div class="card fade-in-up" style="padding:24px;text-align:center;border-color:rgba(34,197,94,.2);">
    <iconify-icon icon="mdi:check-decagram" style="font-size:36px;color:#4ade80;display:block;margin:0 auto 12px;"></iconify-icon>
    <div style="font-size:15px;font-weight:800;color:#4ade80;margin-bottom:6px;">Kamu sudah Reseller VIP!</div>
    <p style="font-size:12px;color:var(--text-3);margin-bottom:16px;">Diskon <strong style="color:var(--blue);"><%= settings.resellerDiscount || 20 %>%</strong> aktif otomatis di semua pembelian.</p>
    <% if (user.reseller_code) { %>
    <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:8px;background:var(--blue-dim);border:1px solid rgba(59,130,246,.3);font-family:monospace;font-size:14px;font-weight:800;color:var(--blue);margin-bottom:6px;">
        <iconify-icon icon="mdi:identifier" style="font-size:16px;"></iconify-icon>
        <%= user.reseller_code %>
    </div>
    <p style="font-size:10px;color:var(--text-3);">Kode identitas reseller kamu</p>
    <% } %>
    <a href="/" class="btn-primary" style="margin-top:20px;padding:10px 24px;font-size:13px;text-decoration:none;">
        <iconify-icon icon="mdi:shopping" style="font-size:15px;"></iconify-icon> Belanja Sekarang
    </a>
</div>

<% } else { %>
<!-- ── BENEFIT LIST ── -->
<div class="card fade-in-up" style="padding:20px;">
    <div style="font-size:12px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:16px;">Keuntungan Bergabung</div>

    <div class="benefit-row">
        <div style="width:36px;height:36px;border-radius:9px;background:var(--blue-dim);border:1px solid rgba(59,130,246,.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <iconify-icon icon="mdi:tag-multiple" style="color:var(--blue);font-size:16px;"></iconify-icon>
        </div>
        <div>
            <div style="font-size:13px;font-weight:700;color:var(--text-1);">Diskon <span style="color:var(--blue);"><%= settings.resellerDiscount || 20 %>%</span> Otomatis Semua Produk</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:3px;">Harga reseller langsung terpotong tanpa perlu input kode apapun.</div>
        </div>
    </div>

    <div class="benefit-row">
        <div style="width:36px;height:36px;border-radius:9px;background:var(--blue-dim);border:1px solid rgba(59,130,246,.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <iconify-icon icon="mdi:lightning-bolt" style="color:var(--blue);font-size:16px;"></iconify-icon>
        </div>
        <div>
            <div style="font-size:13px;font-weight:700;color:var(--text-1);">Harga Langsung Terpotong di Checkout</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:3px;">Harga normal dicoret, harga reseller tampil di setiap pilihan paket.</div>
        </div>
    </div>

    <div class="benefit-row">
        <div style="width:36px;height:36px;border-radius:9px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <iconify-icon icon="mdi:identifier" style="color:#4ade80;font-size:16px;"></iconify-icon>
        </div>
        <div>
            <div style="font-size:13px;font-weight:700;color:var(--text-1);">Kode Reseller Unik</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:3px;">Kode identitas reseller sebagai tanda keanggotaan VIP.</div>
        </div>
    </div>

    <div class="benefit-row">
        <div style="width:36px;height:36px;border-radius:9px;background:var(--blue-dim);border:1px solid rgba(59,130,246,.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <iconify-icon icon="mdi:crown" style="color:var(--blue);font-size:16px;"></iconify-icon>
        </div>
        <div>
            <div style="font-size:13px;font-weight:700;color:var(--text-1);">Badge VIP di Profil & Leaderboard</div>
            <div style="font-size:11px;color:var(--text-3);margin-top:3px;">Status VIP tampil di badge profil dan halaman admin.</div>
        </div>
    </div>
</div>

<!-- ── HARGA & BAYAR ── -->
<div class="card fade-in-up" style="padding:24px;">
    <div style="text-align:center;margin-bottom:20px;">
        <div style="font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Biaya Keanggotaan Reseller VIP</div>
        <div style="font-size:36px;font-weight:900;color:var(--text-1);line-height:1;margin-bottom:6px;">
            Rp <%= (settings.resellerPrice || 50000).toLocaleString('id-ID') %>
        </div>
        <div style="font-size:11px;color:var(--text-3);">Bayar sekali · Diskon <strong style="color:var(--blue);"><%= settings.resellerDiscount || 20 %>%</strong> berlaku selamanya</div>
    </div>

    <% if (!user) { %>
    <a href="/login?redirect=/reseller" class="btn-primary" style="width:100%;padding:13px;font-size:14px;border-radius:10px;text-decoration:none;">
        <iconify-icon icon="mdi:login" style="font-size:16px;"></iconify-icon> Login untuk Bergabung
    </a>
    <p style="font-size:11px;color:var(--text-3);text-align:center;margin-top:10px;">Belum punya akun? <a href="/register" style="color:var(--blue);text-decoration:none;">Daftar gratis</a></p>
    <% } else { %>
    <%
      const waNumber = (settings.contact?.whatsapp || '').replace(/\D/g, '');
      const waMsg = encodeURIComponent(
        'Halo min, saya mau daftar Reseller VIP di ' + (settings.siteName || 'YOOSKY STORE') + ' 🙏\n\n' +
        'Nama akun: ' + (user.username || '-') + '\n' +
        'Email: ' + (user.email || '-') + '\n\n' +
        'Mohon diproses ya, terima kasih!'
      );
    %>
    <a href="https://wa.me/<%= waNumber %>?text=<%= waMsg %>" target="_blank" rel="noopener"
       class="btn-primary" style="width:100%;padding:13px;font-size:14px;border-radius:10px;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,#16a34a,#15803d);">
        <iconify-icon icon="mdi:whatsapp" style="font-size:20px;"></iconify-icon>
        Daftar via WhatsApp Admin
    </a>
    <p style="font-size:11px;color:var(--text-3);text-align:center;margin-top:10px;">
      Kamu akan diarahkan ke WhatsApp admin untuk konfirmasi &amp; aktivasi reseller.
    </p>
    <% } %>
</div>

<% } %>
</div>
</div>


<script>
function showToast(msg, type='info') {
    const wrap = document.getElementById('toast-wrap');
    const el = document.createElement('div');
    el.className = `toast-item toast-${type}`;
    el.textContent = msg;
    wrap.appendChild(el);
    setTimeout(() => { el.style.opacity='0'; el.style.transition='opacity .3s'; setTimeout(()=>el.remove(),300); }, 3500);
}
</script>
</body>
</html>
