<%
const pageTitle = 'Aktifkan Key';
%>

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-[#0d0d20]/95 backdrop-blur-md border-b border-white/5">
    <div class="max-w-lg mx-auto px-4">
        <div class="flex items-center justify-between h-14">
            <a href="/" class="flex items-center gap-2.5">
                <span class="font-bold text-base font-bold shimmer-text"><%= settings.siteName || 'YOOSKY STORE' %></span>
            </a>
            <a href="/" class="flex items-center gap-1.5 text-xs text-zinc-400 hover:text-white px-3 py-1.5 rounded-lg border border-white/10 hover:bg-white/5 transition-all">
                <iconify-icon icon="mdi:arrow-left" class="text-sm"></iconify-icon> Kembali
            </a>
        </div>
    </div>
</nav>

<div class="min-h-screen pt-20 pb-10 px-4">
<div class="max-w-md mx-auto">

    <div class="text-center mb-6 fade-in-up">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-3"
             style="background:linear-gradient(135deg,rgba(37,99,235,.2),rgba(37,99,235,.1));border:1.5px solid rgba(37,99,235,.3);box-shadow:0 0 30px rgba(37,99,235,.15);">
            <iconify-icon icon="mdi:key-chain" class="text-3xl text-blue-400"></iconify-icon>
        </div>
        <h1 class="font-bold text-xl font-black text-white mb-1">Aktifkan Key</h1>
        <p class="text-xs text-zinc-500">Masukkan kode lisensi yang kamu miliki</p>
    </div>

    <!-- FORM -->
    <div class="neon-card p-5 fade-in-up mb-4">
        <form method="POST" action="/activate-key" class="space-y-4">
            <div>
                <label class="block text-xs font-bold text-zinc-400 mb-2">Kode Lisensi</label>
                <input type="text" name="code" required
                    value="<%= code || '' %>"
                    class="hm-input font-mono uppercase tracking-widest text-center text-base font-black"
                    placeholder="Contoh: KEY-A1B2C3"
                    maxlength="30" autofocus
                    style="letter-spacing:.15em"
                    oninput="this.value=this.value.toUpperCase()">
                <p class="text-[10px] text-zinc-600 mt-1.5 text-center">Format: <code class="text-blue-400">KODE - DURASI</code></p>
            </div>

            <% if (error) { %>
            <div class="flex items-center gap-2 p-3 rounded-xl" style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25);">
                <iconify-icon icon="mdi:alert-circle" class="text-red-400 text-lg flex-shrink-0"></iconify-icon>
                <span class="text-xs text-red-400"><%= error %></span>
            </div>
            <% } %>

            <button type="submit" class="btn-gaming w-full py-3 text-sm font-black flex items-center justify-center gap-2">
                <iconify-icon icon="mdi:key-check" class="text-lg"></iconify-icon> Aktifkan Sekarang
            </button>
        </form>
    </div>

    <!-- RESULT — muncul setelah aktivasi berhasil -->
    <% if (result) { %>
    <div class="fade-in-up" style="animation-delay:.1s">
        <div class="rounded-2xl overflow-hidden" style="background:linear-gradient(135deg,rgba(16,185,129,.12),rgba(5,150,105,.06));border:1.5px solid rgba(16,185,129,.35);box-shadow:0 0 30px rgba(16,185,129,.15);">
            <div class="h-1.5" style="background:linear-gradient(90deg,#10b981,#34d399,#10b981);background-size:200%;animation:shimmer 2s linear infinite;"></div>
            <div class="p-6 text-center">
                <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4"
                     style="background:rgba(16,185,129,.2);border:2px solid rgba(16,185,129,.4);">
                    <iconify-icon icon="mdi:check-circle" class="text-emerald-400 text-2xl"></iconify-icon>
                </div>
                <div class="text-xs font-bold text-emerald-400 uppercase tracking-widest mb-2">Aktivasi Berhasil!</div>
                <!-- Format KEY - DURASI -->
                <div class="font-bold text-2xl font-black text-white mb-1">
                    <%= result.code %> — <%= result.duration %> Hari
                </div>
                <% if (result.label && result.label !== result.duration + ' Hari') { %>
                <div class="text-xs text-zinc-400 mb-3"><%= result.label %></div>
                <% } %>
                <% if (result.note) { %>
                <div class="mt-3 p-3 rounded-xl text-xs text-zinc-400" style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);">
                    <iconify-icon icon="mdi:information" class="text-blue-400 mr-1"></iconify-icon>
                    <%= result.note %>
                </div>
                <% } %>
                <div class="mt-4 p-3 rounded-xl text-xs text-zinc-500" style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);">
                    <iconify-icon icon="mdi:clock-check" class="text-emerald-400/70 mr-1"></iconify-icon>
                    Diaktifkan: <%= new Date().toLocaleDateString('id-ID', {day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                </div>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Info cara penggunaan -->
    <div class="neon-card p-4 mt-4 fade-in-up">
        <div class="text-xs font-bold text-zinc-400 mb-3 flex items-center gap-2">
            <iconify-icon icon="mdi:information-outline" class="text-blue-400"></iconify-icon> Cara Penggunaan
        </div>
        <div class="space-y-2">
            <div class="flex items-start gap-2.5">
                <div class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-black text-white flex-shrink-0 mt-0.5" style="background:#6366f1">1</div>
                <p class="text-xs text-zinc-500">Masukkan kode lisensi yang sudah kamu beli atau dapatkan dari admin</p>
            </div>
            <div class="flex items-start gap-2.5">
                <div class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-black text-white flex-shrink-0 mt-0.5" style="background:#6366f1">2</div>
                <p class="text-xs text-zinc-500">Sistem akan memvalidasi key dan menampilkan durasi akses</p>
            </div>
            <div class="flex items-start gap-2.5">
                <div class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-black text-white flex-shrink-0 mt-0.5" style="background:#6366f1">3</div>
                <p class="text-xs text-zinc-500">Satu key hanya bisa digunakan satu kali. Simpan bukti aktivasi kamu</p>
            </div>
        </div>
    </div>

</div>
</div>
